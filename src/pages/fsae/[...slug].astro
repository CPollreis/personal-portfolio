---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import SubsystemBadge from '../../components/fsae/SubsystemBadge.astro';
import VideoEmbed from '../../components/content/VideoEmbed.astro';
import Placeholder from '../../components/media/Placeholder.astro';
import CoordinateAxis from '../../components/hud/CoordinateAxis.astro';
import HeaderMedia from '../../components/layout/HeaderMedia.astro';
import { subsystems } from '../../config/fsae';
import { withBase } from '../../config/paths';

export async function getStaticPaths() {
  const posts = (await getCollection('fsae', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: { post, newer: posts[i - 1] ?? null, older: posts[i + 1] ?? null },
  }));
}

const { post, newer, older } = Astro.props;
const { Content } = await render(post);
const meta = subsystems[post.data.subsystem];
const dateStr = post.data.date.toISOString().slice(0, 10);
/* Media behind the title: dedicated clip, else dedicated hero image, else the cover. */
const heroImg = post.data.hero ?? post.data.cover;
const hasHeroMedia = Boolean(post.data.heroVideo || heroImg);
---

<Base title={post.data.title} description={post.data.summary}>
  <article class="pb-24">
    <!-- header (title in focus over the entry's hero image, home-hero style) -->
    <header
      class:list={[
        'relative overflow-hidden border-b border-line py-10',
        hasHeroMedia ? 'md:py-16' : 'md:py-12',
      ]}
      style={`--sc:${meta.color}`}
    >
      <HeaderMedia video={post.data.heroVideo} image={heroImg} />
      <div class="container-hud relative max-w-3xl">
        <a href={withBase('/#fsae')} class="link-hud mb-8 inline-block font-mono text-xs uppercase tracking-widest text-muted hover:text-ink">
          ← Build log
        </a>
        <div class="mb-5 flex flex-wrap items-center gap-3">
          <SubsystemBadge subsystem={post.data.subsystem} />
          <span class="hud-label tabular">{dateStr}</span>
          {post.data.season && <span class="hud-label">· {post.data.season}</span>}
        </div>
        <h1 class="font-display text-4xl font-semibold leading-tight md:text-5xl">
          {post.data.title}
        </h1>
        <p class="mt-5 text-lg text-muted">{post.data.summary}</p>
        {
          post.data.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {post.data.tags.map((t) => (
                <span class="font-mono text-[0.65rem] uppercase tracking-wider text-faint">#{t}</span>
              ))}
            </div>
          )
        }
      </div>
    </header>

    <div class="container-hud max-w-3xl">
      <!-- lead media: video > cover (unless the header already used it) > placeholder -->
      {
        (post.data.video || (post.data.hero && post.data.cover) || !hasHeroMedia) && (
          <div class="mt-10">
            {post.data.video ? (
              <VideoEmbed url={post.data.video} title={post.data.title} />
            ) : post.data.hero && post.data.cover ? (
              <Image
                src={post.data.cover}
                alt={post.data.title}
                widths={[600, 1000, 1600]}
                sizes="(min-width: 768px) 768px, 100vw"
                class="w-full border border-line object-cover"
              />
            ) : (
              <Placeholder ratio="16/9" label={`${meta.code} · FIG.LEAD`} seed={0} />
            )}
          </div>
        )
      }

      <!-- MDX body -->
      <div class="prose-hud mt-12">
        <Content />
      </div>

      <div class="mt-16">
        <CoordinateAxis startLabel="EOF" endLabel="↑ TOP" />

        <!-- prev / next entry -->
        <nav class="mt-8 grid gap-3 sm:grid-cols-2" aria-label="Adjacent entries">
          {
            older ? (
              <a
                href={withBase(`/fsae/${older.id}`)}
                class="card-hud group border border-line bg-surface p-5 transition-colors"
              >
                <span class="hud-label">← Older</span>
                <span class="mt-2 block font-display text-lg text-ink transition-colors group-hover:text-cyan">
                  {older.data.title}
                </span>
              </a>
            ) : (
              <span />
            )
          }
          {
            newer && (
              <a
                href={withBase(`/fsae/${newer.id}`)}
                class="card-hud group border border-line bg-surface p-5 text-right transition-colors"
              >
                <span class="hud-label">Newer →</span>
                <span class="mt-2 block font-display text-lg text-ink transition-colors group-hover:text-cyan">
                  {newer.data.title}
                </span>
              </a>
            )
          }
        </nav>

        <a
          href={withBase('/#fsae')}
          class="link-hud mt-8 inline-block font-mono text-xs uppercase tracking-widest text-muted hover:text-ink"
        >
          ← Back to all entries
        </a>
      </div>
    </div>
  </article>
</Base>
