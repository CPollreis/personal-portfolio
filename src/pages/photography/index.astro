---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/layout/Section.astro';
import PhotoTile from '../../components/photography/PhotoTile.astro';
import Lightbox, { type Photo } from '../../components/photography/Lightbox.tsx';
import Stagger from '../../components/motion/Stagger.astro';
import Reveal from '../../components/motion/Reveal.astro';
import SpecLabel from '../../components/hud/SpecLabel.astro';
import DimensionLine from '../../components/hud/DimensionLine.astro';
import CoordinateAxis from '../../components/hud/CoordinateAxis.astro';
import LensExplode from '../../components/photography/LensExplode.astro';

const frames = (await getCollection('photography')).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.getTime() - a.data.date.getTime(),
);

// Serializable payload for the lightbox island.
const photos: Photo[] = frames.map((f) => ({
  title: f.data.title,
  date: f.data.date.toISOString().slice(0, 10),
  location: f.data.location,
  camera: f.data.camera,
  lens: f.data.lens,
  settings: f.data.settings,
  coords: f.data.coords,
  ratio: f.data.ratio,
  src: f.data.image?.src,
}));
---

<Base title="Photography" description="Photography by Caleb Pollreis: motorsport, engineering detail, and the world in between.">
  <header class="glow-header relative overflow-hidden border-b border-line py-20 md:py-28">
    <div class="container-hud grid items-center gap-12 lg:grid-cols-[1fr_400px]">
      <div>
        <SpecLabel code="DIV.03" text="OPTICS · PHOTOGRAPHY" accent />
        <div class="mt-6" data-reveal="clip">
          <h1 class="font-display text-5xl font-semibold leading-[0.95] md:text-7xl">
            Through the <span class="text-grad">lens</span>
          </h1>
        </div>
        <div class="mt-6 max-w-xl"><DimensionLine value="MOTORSPORT · DETAIL · LANDSCAPE" /></div>
        <Reveal delay={140}>
          <p class="mt-6 max-w-2xl text-lg text-muted">
            The same eye for systems, pointed at light. Track days, bench macros, and whatever
            catches me between. Click any frame to enlarge.
          </p>
        </Reveal>
      </div>

      <!-- exploded optical formula, animejs.com-style blowup -->
      <div class="relative hidden lg:block">
        <LensExplode class="mx-auto w-full max-w-[400px]" />
        <span class="hud-label absolute -bottom-4 left-1/2 -translate-x-1/2">
          FIG.03 · OPTICAL FORMULA 5E/4G
        </span>
      </div>
    </div>
  </header>

  <Section index="A" label="Gallery" title="Selected frames">
    <div class="mb-10"><CoordinateAxis startLabel="ROLL" endLabel={`${photos.length} FRAMES`} /></div>

    <Stagger class="columns-1 gap-4 sm:columns-2 lg:columns-3" gap={55}>
      {
        frames.map((f, i) => (
          <PhotoTile
            index={i}
            title={f.data.title}
            settings={f.data.settings}
            location={f.data.location}
            ratio={f.data.ratio}
            image={f.data.image}
          />
        ))
      }
    </Stagger>
  </Section>

  <Lightbox client:load photos={photos} />
</Base>
