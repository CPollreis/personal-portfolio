---
/**
 * /photography - "Moments". The creative counterpart to the rest of the site:
 * pure black, huge cropped Archivo display type with frames overlapping it,
 * hairline dividers, and a "Feature Lead" archive grid (archiveGrid.ts) that
 * grows as new entries are added to the collection. Clicking any frame opens
 * the shared-element lightbox.
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import MomentFrame from '../../components/photography/MomentFrame.astro';
import MomentLightbox, { type Moment } from '../../components/photography/MomentLightbox.tsx';
import { momentBackdrop } from '../../components/photography/backdrop';
import { archiveShape, packArchive } from '../../components/photography/archiveGrid';
import { stripArt } from '../../components/photography/stripArt';
import HeaderMedia from '../../components/layout/HeaderMedia.astro';
import { withBase } from '../../config/paths';
import '../../styles/moments.css';

/* Optional footage behind the whole hero, home-hero style: set a video
   (public/ path, e.g. '/videos/hero-loop-web.mp4') or an image path to switch
   it on. It renders beneath the auto-scrolling filmstrip. */
const headerMedia: { video?: string; image?: string } = {};

const frames = (await getCollection('photography')).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.getTime() - a.data.date.getTime(),
);

const fmtDate = (d: Date) =>
  d
    .toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })
    .toUpperCase();

// Serializable payload for the lightbox island.
const moments: Moment[] = frames.map((f, i) => ({
  title: f.data.title,
  kind: f.data.kind,
  dateDisplay: fmtDate(f.data.date),
  story: f.data.story,
  location: f.data.location,
  camera: f.data.camera,
  lens: f.data.lens,
  iso: f.data.iso,
  aperture: f.data.aperture,
  focal: f.data.focal,
  fps: f.data.fps,
  quality: f.data.quality,
  ratio: f.data.ratio,
  src: f.data.image?.src,
  video: f.data.video,
  backdrop: momentBackdrop(i),
}));

const yearOf = (i: number) => String(frames[i].data.date.getUTCFullYear());

const frameProps = (i: number) => ({
  index: i,
  title: frames[i].data.title,
  year: yearOf(i),
  kind: frames[i].data.kind,
  ratio: frames[i].data.ratio,
  image: frames[i].data.image,
  video: frames[i].data.video,
});

// "Feature Lead" archive grid: placements computed from the content
// collection (see archiveGrid.ts), so new entries flow in automatically.
const archive = packArchive(
  frames.map((f, i) => ({ index: i, shape: archiveShape(f.data.ratio, f.data.feature) })),
);
---

<Base
  title="Moments"
  description="A running archive of photos and film by Caleb Pollreis: roads, nights, water, light, and the people along the way."
>
  <div class="moments">
    <!-- ===== HERO: giant cropped wordmark with a frame overlapping it ===== -->
    <header class="relative overflow-hidden border-b border-white/10">
      <HeaderMedia {...headerMedia} />

      <div class="relative mt-4 pb-10 md:mt-2 md:pb-14">
        <!-- ambient filmstrip: an auto-scrolling, non-interactive slideshow of
             the archive drifting behind the wordmark -->
        <div class="m-strip absolute inset-0 z-0" aria-hidden="true">
          <div class="m-strip-track">
            {
              [0, 1].map(() => (
                <div class="flex h-full shrink-0 items-center gap-6 pr-6">
                  {moments.map((m, i) => (
                    <div
                      class="m-strip-cell relative shrink-0 overflow-hidden"
                      style={
                        /* Video cells get a dark ground instead of stripArt:
                           any subpixel seam at the video's edge during the
                           scroll animation must read black, not orange. */
                        m.kind === 'video'
                          ? `aspect-ratio:${m.ratio}; background:#0a0a0a`
                          : `aspect-ratio:${m.ratio}; background-image:${stripArt(i)}; background-size:cover; background-position:center`
                      }
                    >
                      {m.kind === 'video' && (
                        <video
                          data-header-video
                          class="absolute inset-0 h-full w-full object-cover"
                          autoplay
                          muted
                          loop
                          playsinline
                          preload="metadata"
                          tabindex="-1"
                        >
                          <source src={withBase('/videos/hero-loop-web.webm')} type="video/webm" />
                          <source src={withBase('/videos/hero-loop-web.mp4')} type="video/mp4" />
                        </video>
                      )}
                    </div>
                  ))}
                </div>
              ))
            }
          </div>
        </div>
        <div data-reveal="clip">
          <h1 class="m-display relative z-[1] text-center">Moments</h1>
        </div>
      </div>

    </header>

    <!-- ===== ARCHIVE: the "Feature Lead" grid ===== -->
    <section id="archive" class="relative scroll-mt-16">
      <div class="container-hud py-12 md:py-16">
        <div class="m-archive">
          <div class="m-archive-grid">
            {
              archive.placements.map((p) => (
                <div
                  class={`m-cell-${p.shape}`}
                  style={`--ga:${p.row} / ${p.col} / span ${p.rowSpan} / span ${p.colSpan}`}
                  data-reveal
                >
                  <MomentFrame {...frameProps(p.index)} fill />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <MomentLightbox client:load moments={moments} />

    <script>
      /* Archive films play only while on screen: [data-scrollplay] videos are
         excluded from footage.ts's always-on management, so this observer owns
         their playback. Nodes are fresh after every ClientRouter swap; the old
         observer is dropped wholesale and rebuilt. */
      let playIO: IntersectionObserver | undefined;

      function initScrollPlay() {
        playIO?.disconnect();
        const vids = Array.from(
          document.querySelectorAll<HTMLVideoElement>('video[data-scrollplay]'),
        );
        if (!vids.length) return;

        if (window.matchMedia?.('(prefers-reduced-motion: reduce)').matches) {
          vids.forEach((v) => v.pause());
          return;
        }

        playIO = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              const v = e.target as HTMLVideoElement;
              if (e.isIntersecting) {
                v.muted = true; // required for programmatic autoplay
                v.play().catch(() => {});
              } else {
                v.pause();
              }
            }
          },
          { threshold: 0.2 },
        );
        vids.forEach((v) => playIO!.observe(v));
      }

      document.addEventListener('astro:page-load', initScrollPlay);
    </script>
  </div>
</Base>
