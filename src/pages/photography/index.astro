---
/**
 * /photography - "Moments". The creative counterpart to the rest of the site:
 * near-pure black, huge cropped Archivo display type with frames overlapping
 * it, hairline dividers, a bright italic marquee, and an editorial scatter
 * archive. Clicking any frame opens the shared-element lightbox.
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import MomentFrame from '../../components/photography/MomentFrame.astro';
import MomentLightbox, { type Moment } from '../../components/photography/MomentLightbox.tsx';
import { momentBackdrop } from '../../components/photography/backdrop';
import { stripArt } from '../../components/photography/stripArt';
import HeaderMedia from '../../components/layout/HeaderMedia.astro';
import { withBase } from '../../config/paths';
import '../../styles/moments.css';

/* Optional footage behind the whole hero, home-hero style: set a video
   (public/ path, e.g. '/videos/hero-loop-web.mp4') or an image path to switch
   it on. It renders beneath the auto-scrolling filmstrip. */
const headerMedia: { video?: string; image?: string } = {};

const frames = (await getCollection('photography')).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.getTime() - a.data.date.getTime(),
);

const fmtDate = (d: Date) =>
  d
    .toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })
    .toUpperCase();

// Serializable payload for the lightbox island.
const moments: Moment[] = frames.map((f, i) => ({
  title: f.data.title,
  kind: f.data.kind,
  dateDisplay: fmtDate(f.data.date),
  story: f.data.story,
  location: f.data.location,
  camera: f.data.camera,
  lens: f.data.lens,
  iso: f.data.iso,
  aperture: f.data.aperture,
  focal: f.data.focal,
  fps: f.data.fps,
  quality: f.data.quality,
  ratio: f.data.ratio,
  src: f.data.image?.src,
  video: f.data.video,
  backdrop: momentBackdrop(i),
}));

const years = frames.map((f) => f.data.date.getUTCFullYear());
const span = `${Math.min(...years)} – ${Math.max(...years)}`;
const yearOf = (i: number) => String(frames[i].data.date.getUTCFullYear());

const frameProps = (i: number) => ({
  index: i,
  title: frames[i].data.title,
  year: yearOf(i),
  kind: frames[i].data.kind,
  ratio: frames[i].data.ratio,
  image: frames[i].data.image,
  video: frames[i].data.video,
});

// Editorial scatter: column placements + vertical offsets per archive slot.
const LAYOUTS = [
  'col-span-12 md:col-span-7',
  'col-span-9 col-start-4 md:col-span-4 md:col-start-9 md:mt-36',
  'col-span-10 md:col-span-5 md:col-start-2 md:mt-4',
  'col-span-8 col-start-5 md:col-span-3 md:col-start-9 md:-mt-10',
  'col-span-12 md:col-span-6 md:mt-8',
  'col-span-9 md:col-span-4 md:col-start-8 md:mt-28',
  'col-span-7 md:col-span-3 md:col-start-2 md:mt-6',
  'col-span-6 col-start-7 md:col-span-3 md:col-start-7 md:-mt-12',
  'col-span-9 col-start-2 md:col-span-3 md:col-start-10 md:mt-16',
  'col-span-8 md:col-span-4 md:col-start-1 md:mt-10',
  'col-span-12 md:col-span-6 md:col-start-6 md:-mt-4',
  'col-span-12 md:col-span-8 md:col-start-3 md:mt-16',
];

// Contact-sheet connective tissue for the scatter's dead space. Every marker is
// decorative (aria-hidden, desktop-only) and pulls its text from real frame
// data, so nothing here is invented. `place` is the first segment of a real
// location (e.g. "Lake Superior, MN" -> "LAKE SUPERIOR").
const shortPlace = (loc?: string) => (loc ?? '').split(',')[0].trim().toUpperCase();
const tag = (i: number) => ({
  no: String(i + 1).padStart(2, '0'),
  year: yearOf(i),
  place: shortPlace(frames[i].data.location),
});

// "What I chase" call and response: each ghost word is the index entry for one
// moment. The section auto-cycles word + photo together; hovering a word jumps
// the frame to its photo. Indices reference the sorted `frames` order.
const CHASE = [
  { label: 'Long drives', frame: 5 },
  { label: 'City nights', frame: 11 },
  { label: 'Open water', frame: 9 },
  { label: 'Northern lights', frame: 0 },
  { label: 'Race weekends', frame: 1 },
];
---

<Base
  title="Moments"
  description="A running archive of photos and film by Caleb Pollreis: roads, nights, water, light, and the people along the way."
>
  <div class="moments">
    <!-- ===== HERO: giant cropped wordmark with a frame overlapping it ===== -->
    <header class="relative overflow-hidden border-b border-white/10">
      <HeaderMedia {...headerMedia} />
      <div class="container-hud relative flex items-start justify-between pt-10 md:pt-14">
        <span class="m-label" data-reveal>✳ Caleb Pollreis · The other side of the brain</span>
        <p class="hidden max-w-xs text-right text-sm leading-relaxed text-white/55 md:block" data-reveal data-reveal-delay="120">
          Where the engineering stops. A running archive of light, noise, motion, and the people I
          got to share it with.
        </p>
      </div>

      <div class="relative mt-4 md:mt-0">
        <!-- ambient filmstrip: an auto-scrolling, non-interactive slideshow of
             the archive drifting behind the wordmark -->
        <div class="m-strip absolute inset-0 z-0" aria-hidden="true">
          <div class="m-strip-track">
            {
              [0, 1].map(() => (
                <div class="flex h-full shrink-0 items-center gap-6 pr-6">
                  {moments.map((m, i) => (
                    <div
                      class="m-strip-cell relative shrink-0 overflow-hidden"
                      style={
                        /* Video cells get a dark ground instead of stripArt:
                           any subpixel seam at the video's edge during the
                           scroll animation must read black, not orange. */
                        m.kind === 'video'
                          ? `aspect-ratio:${m.ratio}; background:#0a0a0a`
                          : `aspect-ratio:${m.ratio}; background-image:${stripArt(i)}; background-size:cover; background-position:center`
                      }
                    >
                      {m.kind === 'video' && (
                        <video
                          data-header-video
                          class="absolute inset-0 h-full w-full object-cover"
                          autoplay
                          muted
                          loop
                          playsinline
                          preload="metadata"
                          tabindex="-1"
                        >
                          <source src={withBase('/videos/hero-loop-web.webm')} type="video/webm" />
                          <source src={withBase('/videos/hero-loop-web.mp4')} type="video/mp4" />
                        </video>
                      )}
                    </div>
                  ))}
                </div>
              ))
            }
          </div>
        </div>
        <div data-reveal="clip">
          <h1 class="m-display relative z-[1] text-center">Moments</h1>
        </div>
      </div>

      <div class="container-hud relative flex items-end justify-between gap-8 pb-10 pt-12 md:pb-14 md:pt-10">
        <a href="#archive" class="m-scroll" data-reveal>
          <span class="m-scroll-ring">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M6 1v10M2 7l4 4 4-4" stroke="#f5f5f4" stroke-width="1.2" />
            </svg>
          </span>
          scroll down
        </a>
        <p class="max-w-[16rem] text-right text-sm leading-relaxed text-white/55 md:hidden">
          A running archive of light, noise, motion, and the people I got to share it with.
        </p>
      </div>
    </header>

    <!-- ===== ABOUT: statement with overlapping frames ===== -->
    <section class="relative border-b border-white/10">
      <div class="container-hud grid gap-14 py-20 md:grid-cols-[1.15fr_1px_0.85fr] md:gap-0 md:py-28">
        <div class="relative md:pr-14">
          <span class="m-label" data-reveal>✳ About this page</span>
          <div class="mt-8" data-reveal="clip">
            <h2 class="m-statement relative z-[1]">
              Not everything<br />needs a spec sheet.
            </h2>
          </div>
          <div class="relative z-[2] ml-[30%] mt-[-1rem] w-[58%] md:mt-[-2.25rem]" data-reveal data-reveal-delay="180">
            <MomentFrame {...frameProps(6)} caption={false} />
          </div>
          <p class="relative z-[3] ml-auto mt-[-3rem] max-w-md bg-[#050505]/85 p-4 text-sm leading-relaxed text-white/65 backdrop-blur-sm md:mt-[-4.5rem]" data-reveal data-reveal-delay="300">
            The rest of this site is the engineering half: benches, builds, telemetry. This page is
            everything those pages leave out. Some of it is sharp, some of it is grain at ISO 6400,
            and every frame earned its spot by being a night I still think about.
          </p>
        </div>

        <div class="m-hairline-y hidden md:block" aria-hidden="true"></div>

        <div class="relative md:pl-14">
          <div class="md:mt-24" data-reveal data-reveal-delay="140">
            <MomentFrame {...frameProps(3)} />
          </div>
        </div>
      </div>
    </section>

    <!-- ===== MARQUEE: ghost list crossed by a bright italic line ===== -->
    <section class="relative overflow-hidden border-b border-white/10 py-20 md:py-28">
      <div class="container-hud">
        <span class="m-label" data-reveal>✳ What I chase</span>
      </div>

      <div class="relative mt-12">
        <div class="flex flex-col gap-1 pl-[10%] md:pl-[42%]" data-reveal>
          {
            CHASE.map((c, i) => (
              <span class={`m-ghost m-chase-word${i === 0 ? ' is-lit' : ''}`} data-chase-word>
                {c.label}
              </span>
            ))
          }
        </div>

        <!-- bright line crossing the middle, full-bleed -->
        <div class="ticker absolute inset-x-0 top-1/2 z-[2] -translate-y-1/2" aria-hidden="true">
          <div class="ticker-track">
            {
              [0, 1].map(() => (
                <span class="m-marquee-text pr-4">
                  chasing light · chasing light · chasing light · chasing light · chasing light ·&nbsp;
                </span>
              ))
            }
          </div>
        </div>

        <!-- portrait frame overlapping the list: a stack of one photo per ghost
             word, crossfading in step with the lit word -->
        <div class="absolute left-[6%] top-1/2 z-[3] hidden w-[220px] -translate-y-1/2 md:block" data-reveal data-reveal-delay="160">
          <div class="m-chase-stack">
            {
              CHASE.map((c, i) => (
                <div class={`m-chase-slide${i === 0 ? ' is-lit' : ''}`} data-chase-slide>
                  <MomentFrame {...frameProps(c.frame)} caption={false} />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ===== ARCHIVE: the scatter grid ===== -->
    <section id="archive" class="relative scroll-mt-16">
      <div class="container-hud py-20 md:py-28">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <span class="m-label" data-reveal>✳ The archive</span>
          <span class="text-[0.72rem] font-medium uppercase tracking-[0.16em] text-white/40" data-reveal>
            {moments.length} moments · {span}
          </span>
        </div>

        <div class="relative mt-16 grid grid-cols-12 gap-x-5 gap-y-16 md:gap-x-7 md:gap-y-24">
          <!-- Light-table substrate: quiet connective tissue that fills the
               scatter's dead space so the layout reads as art-directed, not
               accidental. Ruled column guides, crosshair registration marks,
               oversized ghost catalog numbers, and mono index tags (real frame
               data). Purely decorative, behind the prints, desktop-only. -->
          <div class="m-archive-field hidden md:block" aria-hidden="true">
            <div class="m-field-grid"></div>

            <!-- oversized ghost catalog numerals drifting in the big pockets -->
            <span class="m-field-num" style="top:-2%; left:59%">{tag(0).no}</span>
            <span class="m-field-num" style="top:40%; left:0.5%">{tag(6).no}</span>
            <span class="m-field-num" style="top:79%; left:66%">{tag(11).no}</span>

            <!-- mono index tags, each drawn from a real frame -->
            <span class="m-field-tag" style="top:15%; left:29%">
              NO. <b>{tag(3).no}</b> · {tag(3).year}<br />{tag(3).place}
            </span>
            <span class="m-field-tag" style="top:32%; right:5%; text-align:right">
              NO. <b>{tag(5).no}</b> · {tag(5).year}<br />{tag(5).place}
            </span>
            <span class="m-field-tag" style="top:59%; left:45%">
              NO. <b>{tag(7).no}</b> · {tag(7).year}<br />{tag(7).place}
            </span>
            <span class="m-field-tag" style="top:73%; left:9%">
              NO. <b>{tag(9).no}</b> · {tag(9).year}<br />{tag(9).place}
            </span>

            <!-- registration crosshairs, like a print proofing sheet -->
            <span class="m-plus" style="top:9%; left:56%"></span>
            <span class="m-plus" style="top:27%; left:7%"></span>
            <span class="m-plus" style="top:51%; left:69%"></span>
            <span class="m-plus" style="top:57%; left:32%"></span>
            <span class="m-plus" style="top:70%; left:87%"></span>
            <span class="m-plus" style="top:88%; left:58%"></span>

            <!-- film-strip connector hairlines between staggered frames -->
            <span class="m-field-rule" style="top:19%; left:56%; height:14%"></span>
            <span class="m-field-rule" style="top:61%; left:32%; height:12%"></span>
          </div>

          {
            frames.map((_, i) => (
              <div class={`${LAYOUTS[i] ?? 'col-span-12 md:col-span-6'} relative z-[1]`} data-reveal>
                <MomentFrame {...frameProps(i)} />
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <MomentLightbox client:load moments={moments} />

    <script>
      /* "What I chase" call and response: one ghost word lights up while its
         photo swaps into the frame; hovering a word jumps straight to it.
         Nodes are fresh after every ClientRouter swap, so listeners rebind per
         pass; only the interval needs clearing between passes. */
      let chaseTimer: number | undefined;

      function initChase() {
        window.clearInterval(chaseTimer);
        const words = Array.from(document.querySelectorAll<HTMLElement>('[data-chase-word]'));
        const slides = Array.from(document.querySelectorAll<HTMLElement>('[data-chase-slide]'));
        if (!words.length || words.length !== slides.length) return;

        const reduced = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches ?? false;
        let active = 0;

        const show = (next: number) => {
          active = next;
          words.forEach((w, i) => w.classList.toggle('is-lit', i === active));
          slides.forEach((s, i) => s.classList.toggle('is-lit', i === active));
        };

        const start = () => {
          if (reduced) return;
          window.clearInterval(chaseTimer);
          chaseTimer = window.setInterval(() => show((active + 1) % words.length), 3400);
        };

        words.forEach((w, i) => {
          w.addEventListener('pointerenter', () => {
            window.clearInterval(chaseTimer);
            show(i);
          });
          w.addEventListener('pointerleave', start);
        });

        show(0);
        start();
      }

      document.addEventListener('astro:page-load', initChase);
    </script>
  </div>
</Base>
