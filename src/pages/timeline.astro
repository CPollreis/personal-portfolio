---
/**
 * /timeline - "A universe of moments": a single channel down the page with
 * every moment branching off it in date order. A fixed, stroke-outlined year
 * numeral rides the right edge and follows the scroll, so you always know
 * which year you are in. Fully server-rendered; JavaScript only drives the
 * ghost numeral and the reveal motion.
 */
import Base from '../layouts/Base.astro';
import Spine from '../components/timeline/Spine.astro';
import { timeline } from '../config/timeline';

const eventCount = timeline.reduce((n, y) => n + y.events.length, 0);
---

<Base
  title="Timeline"
  description="A scrolling timeline of Caleb Pollreis's journey since 2022: university, FSAE Electric, projects, and photography, one moment at a time."
>
  <header class="glow-header relative overflow-hidden">
    <div class="container-hud relative py-14 md:py-18">
      <p class="hud-label">
        04 · Timeline <span class="text-cyan">·</span> {eventCount} moments since 2022
      </p>
      <h1 class="mt-3 font-display text-4xl text-ink md:text-5xl">A universe of moments</h1>
      <p class="mt-3 max-w-md text-sm text-muted">
        One line through five years. Scroll, and the year on the right keeps pace with you.
      </p>
    </div>
  </header>

  <Spine />
</Base>
