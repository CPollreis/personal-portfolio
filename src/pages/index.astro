---
import Base from '../layouts/Base.astro';
import Section from '../components/layout/Section.astro';
import Reveal from '../components/motion/Reveal.astro';
import Stagger from '../components/motion/Stagger.astro';
import ScrambleText from '../components/motion/ScrambleText.astro';
import SpecLabel from '../components/hud/SpecLabel.astro';
import Reticle from '../components/hud/Reticle.astro';
import CircuitTrace from '../components/hud/CircuitTrace.astro';
import DataReadout from '../components/hud/DataReadout.astro';
import CoordinateAxis from '../components/hud/CoordinateAxis.astro';
import DimensionLine from '../components/hud/DimensionLine.astro';
import { site } from '../config/site';
---

<Base>
  <Section index="00" label="Kit smoke test" framed headingLevel="h1">
    <div class="flex items-start gap-8">
      <Reticle size={100} />
      <div>
        <h1 class="text-4xl font-semibold md:text-6xl">
          <ScrambleText as="span" text={site.name} />
        </h1>
        <Reveal delay={120}><p class="mt-4 max-w-xl text-lg text-muted">{site.tagline}</p></Reveal>
      </div>
    </div>

    <div class="mt-10"><CoordinateAxis startLabel="000" endLabel="EOL" /></div>

    <Stagger class="mt-10 grid grid-cols-2 gap-6 md:grid-cols-3">
      <DataReadout label="Seasons" value={3} suffix="+" unit="yrs" />
      <DataReadout label="Subsystems" value={3} unit="lanes" />
      <DataReadout label="Commits" value={1240} suffix="+" unit="git" />
    </Stagger>

    <div class="mt-10 max-w-md"><DimensionLine value="220 mm" /></div>
    <SpecLabel class="mt-6" code="FIG.01" text="DRIVERLESS STACK v2.3" accent />
    <div class="mt-10 max-w-lg text-accent"><CircuitTrace /></div>
  </Section>
</Base>
