<script>
  /* Build-log filter: rail (desktop) and chips (mobile) share [data-log-filter]
     buttons and toggle [data-log-entry] cards by data-cat. The `fsae` filter is
     a parent that matches all three subsystems (fw/mfg/av). Clicking the active
     filter again clears back to all.

     Deep-links preselect a filter: #projects -> Projects (Nav breadcrumb, 404,
     project pages), #buildlog -> All entries (hero My work button).
     Two arrival paths, handled separately: cross-page nav fires astro:page-load
     (initLogFilter re-runs and reads location.hash); a same-page hero click is
     intercepted by ClientRouter, which updates the hash via history.pushState
     with NO hashchange event and NO swap, so we also bind the filter straight
     onto those anchors' click. Nodes are fresh after every swap, so everything
     re-initializes on astro:page-load. */
  const HASH_FILTER: Record<string, string> = { '#projects': 'prj', '#buildlog': 'all' };
  const FSAE_CATS = new Set(['fw', 'mfg', 'av']);
  const showsEntry = (id: string, cat: string) =>
    id === 'all' || cat === id || (id === 'fsae' && FSAE_CATS.has(cat));
  let hashHandler: (() => void) | undefined;

  function initLogFilter() {
    const root = document.getElementById('buildlog');
    if (hashHandler) {
      window.removeEventListener('hashchange', hashHandler);
      hashHandler = undefined;
    }
    if (!root) return;

    const btns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-log-filter]'));
    const items = Array.from(root.querySelectorAll<HTMLElement>('[data-log-entry]'));
    let active = 'all';

    const set = (id: string) => {
      active = id;
      for (const b of btns) b.setAttribute('aria-pressed', String(b.dataset.logFilter === id));
      for (const el of items) {
        el.style.display = showsEntry(id, el.dataset.cat ?? '') ? '' : 'none';
      }
    };

    for (const b of btns) {
      b.addEventListener('click', () => {
        const id = b.dataset.logFilter ?? 'all';
        set(id === active && id !== 'all' ? 'all' : id);
      });
    }

    // Filter header reset: clears back to All entries.
    root.querySelector<HTMLButtonElement>('[data-log-reset]')?.addEventListener('click', () => set('all'));

    // Hero deep-link anchors: set the filter on click (the default scroll to the
    // target still runs). Covers the same-page case that hashchange misses.
    for (const a of document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')) {
      const id = HASH_FILTER[a.getAttribute('href') ?? ''];
      if (id) a.addEventListener('click', () => set(id));
    }

    hashHandler = () => {
      const id = HASH_FILTER[location.hash];
      if (id) set(id);
    };
    window.addEventListener('hashchange', hashHandler);

    set('all');
    hashHandler();
  }

  document.addEventListener('astro:page-load', initLogFilter);
</script>

<!-- keyframes the lightbox references for its fade-in and info-panel slide
     (defined in moments.css for /photography; scoped copy for this page) -->
<style is:global>
  /* Timeline teaser ghost year: stroke-outlined transparent numeral, sized to
     fill the card's right side. Matches the .tls-ghost-num motif on /timeline. */
  .tls-teaser-ghost {
    font-size: clamp(5rem, 13vw, 8.5rem);
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--color-line) 88%, var(--color-accent));
  }
  @keyframes m-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes m-slide {
    from { opacity: 0; transform: translateX(28px); }
    to { opacity: 1; transform: none; }
  }
</style>
