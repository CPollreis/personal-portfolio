---
/**
 * Home - the whole site on one page.
 *
 * Structure (anchors match the nav): compact bio hero with the car footage
 * kept small behind a blurred text panel, then #about, #fsae (which hosts the
 * unified work log), #photography, #timeline. Everything a visitor needs is
 * reachable without guessing; deep pages (post writeups, the gallery, the
 * timeline) hang off their sections.
 *
 * The build log is one filterable feed: FSAE entries and personal projects
 * together, filtered by a two-tier index rail on desktop (top-level Projects
 * and FSAE, the latter fanning into its three subsystems) that collapses to
 * chips on mobile. The hero work buttons deep-link into it: #projects lands
 * with the Projects filter preselected, #buildlog with the FSAE grouping.
 * (Nav breadcrumbs, 404, and project pages also link to #projects.)
 *
 * Content sources: src/config/site.ts (positions, links, availability),
 * src/config/fsae.ts (subsystem metadata), and the fsae/projects/photography
 * content collections. To append a project or post, add a file to the
 * collection; to change a position, edit site.ts. (The FSAE role trajectory
 * now lives on the /timeline spine, not here.)
 */
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import SubsystemBadge from '../components/fsae/SubsystemBadge.astro';
import SocialIcon from '../components/ui/SocialIcon.astro';
import Button from '../components/ui/Button.astro';
import Placeholder from '../components/media/Placeholder.astro';
import MomentLightbox, { type Moment } from '../components/photography/MomentLightbox.tsx';
import { momentBackdrop } from '../components/photography/backdrop';
import { subsystems, type Subsystem } from '../config/fsae';
import { site, positions, socials } from '../config/site';
import { timeline } from '../config/timeline';
import { withBase } from '../config/paths';

const fsaePosts = (await getCollection('fsae', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.getTime() - a.data.date.getTime(),
);

/* Unified work log: FSAE entries and personal projects in one feed, newest
   first. `cat` drives the client-side filter; `code` labels placeholders. */
type LogCat = 'fw' | 'mfg' | 'av' | 'prj';
const subsystemCat: Record<Subsystem, LogCat> = {
  firmware: 'fw',
  manufacturing: 'mfg',
  autonomous: 'av',
};
const feed = [
  ...fsaePosts.map((p) => ({
    href: withBase(`/fsae/${p.id}`),
    cat: subsystemCat[p.data.subsystem],
    subsystem: p.data.subsystem as Subsystem | null,
    code: subsystems[p.data.subsystem].code,
    title: p.data.title,
    summary: p.data.summary,
    date: p.data.date,
    cover: p.data.cover,
  })),
  ...projects.map((p) => ({
    href: withBase(`/projects/${p.id}`),
    cat: 'prj' as LogCat,
    subsystem: null as Subsystem | null,
    code: 'PRJ',
    title: p.data.title,
    summary: p.data.summary,
    date: p.data.date,
    cover: p.data.cover,
  })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

/* Rail is two-tier: top-level Projects and FSAE, and FSAE fans out into its
   three subsystems (indented one level on desktop). `level` drives that indent;
   the `fsae` row is a parent filter that matches all three subsystems at once.
   --fc paints the active state (border on the rail, fill on the mobile chips),
   --ftc is the text color on that fill. All and PRJ stay neutral so the FSAE
   family keeps owning the blue. */
const catCount = (c: LogCat) => feed.filter((e) => e.cat === c).length;
const fsaeCount = catCount('fw') + catCount('mfg') + catCount('av');
const logFilters = [
  { id: 'all', label: 'All entries', count: feed.length, fc: 'var(--color-ink)', ftc: 'var(--color-bg)', level: 0 },
  { id: 'prj', label: 'Projects', count: catCount('prj'), fc: 'var(--color-ink)', ftc: 'var(--color-bg)', level: 0 },
  { id: 'fsae', label: 'FSAE', count: fsaeCount, fc: 'var(--color-accent)', ftc: 'var(--color-ink)', level: 0 },
  { id: 'av', label: 'Autonomy', count: catCount('av'), fc: 'var(--color-indigo)', ftc: 'var(--color-ink)', level: 1 },
  { id: 'fw', label: 'Firmware', count: catCount('fw'), fc: 'var(--color-accent)', ftc: 'var(--color-ink)', level: 1 },
  { id: 'mfg', label: 'Manufacturing', count: catCount('mfg'), fc: 'var(--color-cyan)', ftc: 'var(--color-bg)', level: 1 },
];
/* Photography frames in the same sorted order the gallery uses, so a highlight's
   index lines up with its generated backdrop art on /photography. Highlighted =
   the featured moments first, then filled by order, capped at three thumbnails. */
const photoFrames = (await getCollection('photography')).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.getTime() - a.data.date.getTime(),
);
const momentCount = photoFrames.length;
const seenPhoto = new Set<number>();
const photoHighlights = [
  ...photoFrames.map((f, i) => ({ f, i })).filter((x) => x.f.data.feature),
  ...photoFrames.map((f, i) => ({ f, i })),
]
  .filter((x) => (seenPhoto.has(x.i) ? false : seenPhoto.add(x.i)))
  .slice(0, 3);

/* Full serialized payload for the in-page lightbox, indexed to match photoFrames
   so a highlight's data-moment-index lines up. Clicking a highlight opens the
   viewer; arrow keys / the prev-next buttons then step through every moment. */
const fmtMomentDate = (d: Date) =>
  d
    .toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })
    .toUpperCase();
const moments: Moment[] = photoFrames.map((f, i) => ({
  title: f.data.title,
  kind: f.data.kind,
  dateDisplay: fmtMomentDate(f.data.date),
  story: f.data.story,
  location: f.data.location,
  camera: f.data.camera,
  lens: f.data.lens,
  iso: f.data.iso,
  aperture: f.data.aperture,
  focal: f.data.focal,
  fps: f.data.fps,
  quality: f.data.quality,
  ratio: f.data.ratio,
  src: f.data.image?.src,
  video: f.data.video,
  backdrop: momentBackdrop(i),
}));
const eventCount = timeline.reduce((n, y) => n + y.events.length, 0);
/* Latest year on the spine: drives the ghost numeral on the timeline teaser
   card, echoing the stroke-outlined year that rides the right edge of the
   /timeline page. */
const latestYear = timeline[timeline.length - 1].year;

/* Three real stars for the timeline teaser: the earliest, a middle, and the
   latest weight-2 event, so the card previews the actual spine instead of a
   decorative motif. */
const stars = timeline.flatMap((y) =>
  y.events.filter((e) => e.weight === 2).map((e) => ({ year: y.year, title: e.title })),
);
const timelineTeaser = [stars[0], stars[Math.floor(stars.length / 2)], stars[stars.length - 1]];

const fmtDate = (d: Date) =>
  d
    .toLocaleDateString('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' })
    .toUpperCase();

/* Shared thumbnail frame classes: light grey outline, YouTube-card style. */
const thumbFrame = 'border border-faint/50 transition-colors group-hover:border-faint';

/* About data modules that fill the space beside the portrait: a stat rail and
   the toolchain (board options 01 + 02). Real numbers off the FSAE work. */
const aboutStats = [
  { n: '2022', l: 'Building since' },
  { n: '10+', l: 'Team led' },
  { n: '400 V', l: 'Accumulator' },
  { n: '2028', l: 'Driverless target' },
];
/* Toolchain: the autonomy + firmware skills off the resume (public/resume.pdf).
   Flagship two (C++, ROS 2) highlighted; the rest split firmware/embedded
   (STM32, FreeRTOS, CAN, C) and autonomy/perception (Jetson Orin, CUDA,
   TensorRT, PyTorch, OpenCV, Eigen). */
const toolchain = [
  { name: 'C++', hot: true },
  { name: 'ROS 2', hot: true },
  { name: 'C', hot: false },
  { name: 'Python', hot: false },
  { name: 'STM32', hot: false },
  { name: 'FreeRTOS', hot: false },
  { name: 'CAN', hot: false },
  { name: 'Jetson Orin', hot: false },
  { name: 'CUDA', hot: false },
  { name: 'TensorRT', hot: false },
  { name: 'PyTorch', hot: false },
  { name: 'OpenCV', hot: false },
  { name: 'Eigen', hot: false },
];
---

<Base padTop={false}>
  <!-- ============ hero: full-screen footage, who / where / what ============ -->
  <!-- Full viewport so the car footage is the hero's visual object; the text
       sits in a compact panel on the left and the work buttons jump to the
       on-page sections below. -->
  <section class="relative flex min-h-[100dvh] flex-col justify-center overflow-hidden border-b border-line pt-16">
    <!-- background footage layer -->
    <div class="absolute inset-0" aria-hidden="true">
      <video
        data-header-video
        class="h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        tabindex="-1"
      >
        <!-- stabilized variants (ffmpeg vidstab from hero-loop.MP4); webm first:
             Firefox's macOS H.264 decoder can fail after client-side navigation
             (see src/scripts/footage.ts); VP9 decodes in software -->
        <source src={withBase('/videos/hero-loop-stab-web.webm')} type="video/webm" />
        <source src={withBase('/videos/hero-loop-stab-web.mp4')} type="video/mp4" />
      </video>
      <!-- dimming: heavy on the text side, fading to nothing on the right so the
           footage itself carries the right half of the frame -->
      <div class="absolute inset-0 bg-bg/40"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-bg/85 via-bg/35 via-45% to-transparent"></div>
      <!-- fade the footage into the page so the next section meets it seamlessly -->
      <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-bg to-transparent"></div>
    </div>

    <div class="container-hud relative py-20">
      <!-- blurred panel, sized to hug the text (no empty space on the right) -->
      <div class="w-fit max-w-lg border border-line/80 bg-bg/60 p-6 backdrop-blur-md md:p-8">
        <p class="hud-label">Portfolio</p>
        <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight md:text-5xl">
          Caleb <span class="text-grad">Pollreis</span>
        </h1>

        <ul class="mt-5 space-y-1.5">
          {
            positions.map((p) => (
              <li class="text-sm text-muted">
                {p.href ? (
                  <a href={p.href} class="link-hud text-ink">{p.role}</a>
                ) : (
                  <span class="text-ink">{p.role}</span>
                )}
                <span class="text-faint"> · </span>{p.org}
                {p.note && <span class="mt-0.5 block font-medium text-cyan">{p.note}</span>}
              </li>
            ))
          }
        </ul>

        <p class="mt-5 max-w-sm text-sm leading-relaxed text-muted">
          My student team designs and builds an electric race car from scratch. Day to
          day, I make system design choices that bring our team one step closer to a
          driverless car by 2028. Off the team I build personal projects and shoot
          photography.
        </p>

        <p class="mt-6 flex items-center gap-2.5">
          <span class="h-1.5 w-1.5 rounded-full bg-cyan" aria-hidden="true"></span>
          <span class="hud-label text-ink">{site.availability}</span>
        </p>

        <!-- action row: work buttons jump to the build log (#buildlog) / open the
             resume; social icons sit in the opposite corner, inline with them. -->
        <div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-4">
          <div class="flex flex-wrap gap-3">
            <Button href="#buildlog" size="sm">Work</Button>
            <Button href={site.resume} variant="ghost" size="sm" external>Resume</Button>
          </div>

          <ul class="flex items-center gap-x-5">
            {
              socials.map((s) => (
                <li>
                  <a
                    href={s.href}
                    class="link-hud inline-flex text-muted hover:text-ink"
                    aria-label={s.label}
                    rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                    target={s.href.startsWith('http') ? '_blank' : undefined}
                  >
                    <SocialIcon
                      label={s.label}
                      class={s.label === 'Email' ? 'h-5 w-5' : 'h-[18px] w-[18px]'}
                    />
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ About ============ -->
  <section id="about" class="scroll-mt-16">
    <div class="container-hud pt-12 md:pt-16">
      <!-- about strip, photo-led: the portrait takes half the section and the
           intro leads with an oversized statement line above the description.
           Swap the Placeholder for an <Image> once the portrait exists. -->
      <p class="hud-title">About</p>
      <div class="mt-8 grid gap-6 md:grid-cols-[1fr_2fr] md:items-start md:gap-10">
        <div>
          <Placeholder
            ratio="3/4"
            label="CP · REPLACE"
            seed={3}
            class="!border-faint/50"
          />
        </div>
        <div>
          <h2 class="max-w-md text-balance font-display text-2xl font-medium leading-tight tracking-tight md:text-3xl">
            The best way to understand something is to <span class="text-grad">build it from scratch.</span>
          </h2>
          <p class="mt-4 max-w-xl text-sm leading-relaxed text-muted">
            I'm a computer engineering student in Winnipeg. Off the race car I chase personal
            projects end to end and keep a camera close. The work below is where that goes when
            no one assigns it.
          </p>
          <p class="mt-5 font-mono text-xs tracking-wide text-cyan">/ Caleb Pollreis</p>

          <!-- data modules filling the space beside the portrait: the stat rail
               and the toolchain (board options 01 + 02). -->
          <div class="mt-10 border-t border-line pt-10">
            <div class="grid grid-cols-2 gap-px border border-line bg-line sm:grid-cols-4">
              {
                aboutStats.map((s) => (
                  <div class="bg-surface px-4 py-5">
                    <div class="tabular font-display text-2xl font-semibold tracking-tight text-ink">
                      {s.n}
                    </div>
                    <p class="hud-label mt-1.5">{s.l}</p>
                  </div>
                ))
              }
            </div>

            <div class="mt-8">
              <p class="hud-label">Toolchain</p>
              <ul class="mt-3 flex flex-wrap gap-2">
                {
                  toolchain.map((t) => (
                    <li
                      class:list={[
                        'border px-2.5 py-1 font-mono text-xs tracking-wide',
                        t.hot ? 'border-cyan/45 text-cyan' : 'border-line text-muted',
                      ]}
                    >
                      {t.name}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Build log ============ -->
  <!-- One filterable feed of FSAE entries and personal projects. The newest
       entry leads as a wide feature card, the rest follow as thumbnail cards.
       Desktop filters via the sticky two-tier index rail; mobile collapses to
       notched chips. #projects lands here with the Projects filter preselected
       and #buildlog with the FSAE grouping (see the script at the bottom of
       this page). The FSAE role trajectory that used to head this section now
       lives on the /timeline spine. -->
  <section id="fsae" class="scroll-mt-16 border-b border-line">
    <div class="container-hud py-16 md:py-24">
      <p id="projects" class="hud-title scroll-mt-16 border-b border-line pb-3">
        Build log · {feed.length} entries
      </p>

      <div id="buildlog" class="mt-6 scroll-mt-16 md:grid md:grid-cols-[200px_minmax(0,1fr)] md:items-start md:gap-8">
        <nav class="hidden md:sticky md:top-20 md:block" aria-label="Filter the build log">
          <!-- filter header: names the rail as a control (board option 01). The
               reset button clears back to All entries. -->
          <div class="mb-1 flex items-center gap-2 border-b border-line px-3.5 pb-2.5">
            <svg class="h-3 w-3 shrink-0 text-cyan" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path
                d="M1 2h10l-4 4.5V11L5 9.5V6.5L1 2Z"
                stroke="currentColor"
                stroke-width="1"
                stroke-linejoin="round"
              />
            </svg>
            <span class="font-mono text-[0.625rem] uppercase tracking-[0.18em] text-ink">Filter</span>
            <button
              type="button"
              data-log-reset
              class="ml-auto font-mono text-[0.5625rem] uppercase tracking-[0.14em] text-faint transition-colors hover:text-ink"
            >
              Reset
            </button>
          </div>
          <ul class="border-l border-line">
            {
              logFilters.map((f) => (
                <li>
                  <button
                    type="button"
                    data-log-filter={f.id}
                    aria-pressed={f.id === 'all' ? 'true' : 'false'}
                    style={`--fc:${f.fc}`}
                    class:list={[
                      '-ml-px flex w-full items-center justify-between gap-4 border-l-2 border-transparent py-2.5 pr-3.5 font-mono text-[0.625rem] uppercase tracking-[0.14em] text-muted transition-colors hover:text-ink aria-pressed:border-(--fc) aria-pressed:bg-raised aria-pressed:text-ink',
                      f.level === 1 ? 'pl-8' : 'pl-3.5',
                    ]}
                  >
                    <span>{f.label}</span>
                    <span class="tabular text-faint">{f.count}</span>
                  </button>
                </li>
              ))
            }
          </ul>
        </nav>

        <div>
          <div class="mb-6 flex flex-wrap gap-2 md:hidden" role="group" aria-label="Filter the build log">
            {
              logFilters.map((f) => (
                <button
                  type="button"
                  data-log-filter={f.id}
                  aria-pressed={f.id === 'all' ? 'true' : 'false'}
                  style={`--fc:${f.fc};--ftc:${f.ftc}`}
                  class="bg-raised px-3.5 py-2 font-mono text-[0.625rem] uppercase tracking-[0.14em] text-muted transition-colors [clip-path:polygon(0_0,calc(100%-8px)_0,100%_8px,100%_100%,0_100%)] aria-pressed:bg-(--fc) aria-pressed:text-(--ftc)"
                >
                  {f.label} <span class="tabular opacity-70">{f.count}</span>
                </button>
              ))
            }
          </div>

          {
            feed.length > 0 && (
              <a
                href={feed[0].href}
                data-log-entry
                data-cat={feed[0].cat}
                class="group grid gap-6 md:grid-cols-[3fr_2fr] md:items-center"
              >
                {feed[0].cover ? (
                  <div class={thumbFrame}>
                    <Image
                      src={feed[0].cover}
                      alt={feed[0].title}
                      widths={[720, 1440]}
                      sizes="(min-width: 768px) 60vw, 100vw"
                      class="aspect-video w-full object-cover"
                    />
                  </div>
                ) : (
                  <Placeholder
                    ratio="16/9"
                    label={`${feed[0].code} · FIG.LEAD`}
                    seed={0}
                    class="!border-faint/50 transition-colors group-hover:!border-faint"
                  />
                )}
                <div>
                  <div class="flex flex-wrap items-center gap-3">
                    {feed[0].subsystem ? (
                      <SubsystemBadge subsystem={feed[0].subsystem} />
                    ) : (
                      <span class="inline-flex items-center gap-1.5 border border-ink/45 px-2 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-ink">
                        <span class="h-1.5 w-1.5 bg-ink" />
                        Project
                      </span>
                    )}
                    <span class="hud-label tabular">{fmtDate(feed[0].date)}</span>
                  </div>
                  <h3 class="mt-3 font-display text-xl text-ink transition-colors group-hover:text-cyan md:text-2xl">
                    {feed[0].title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-muted">{feed[0].summary}</p>
                  <span class="hud-label mt-4 inline-flex transition-colors group-hover:text-cyan">
                    Read the entry →
                  </span>
                </div>
              </a>
            )
          }
          <ul class="mt-10 grid gap-x-6 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
            {
              feed.slice(1).map((e, i) => (
                <li data-log-entry data-cat={e.cat}>
                  <a href={e.href} class="group block">
                    {e.cover ? (
                      <div class={thumbFrame}>
                        <Image
                          src={e.cover}
                          alt={e.title}
                          widths={[480, 960]}
                          sizes="(min-width: 1024px) 430px, (min-width: 640px) 50vw, 100vw"
                          class="aspect-video w-full object-cover"
                        />
                      </div>
                    ) : (
                      <Placeholder
                        ratio="16/9"
                        label={`${e.code} · FIG.0${i + 2}`}
                        seed={i + 1}
                        class="!border-faint/50 transition-colors group-hover:!border-faint"
                      />
                    )}
                    <div class="mt-3 flex flex-wrap items-center gap-3">
                      {e.subsystem ? (
                        <SubsystemBadge subsystem={e.subsystem} />
                      ) : (
                        <span class="inline-flex items-center gap-1.5 border border-ink/45 px-2 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-ink">
                          <span class="h-1.5 w-1.5 bg-ink" />
                          Project
                        </span>
                      )}
                      <span class="hud-label tabular">{fmtDate(e.date)}</span>
                    </div>
                    <h3 class="mt-2 font-display text-base text-ink transition-colors group-hover:text-cyan">
                      {e.title}
                    </h3>
                    <p class="mt-1 line-clamp-2 text-sm text-muted">{e.summary}</p>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Photography / Timeline ============ -->
  <div class="border-b border-line">
    <div class="container-hud grid gap-px py-12 md:grid-cols-2 md:gap-6 md:py-16">
      <section id="photography" class="scroll-mt-16">
        <div class="card-hud relative flex h-full flex-col gap-6 border border-line bg-surface p-6">
          <a href={withBase('/photography')} class="group/head block">
            <p class="hud-title transition-colors group-hover/head:text-cyan">Photography</p>
            <p class="mt-2 max-w-md text-sm text-muted">
              {momentCount} moments from the field: race cars, prairie storms, and Winnipeg at
              minus 30.
            </p>
          </a>

          <!-- highlighted frames: click any to open the viewer in place, then
               arrow / click through every moment. Drawn with the same generated
               art the gallery uses so indices (and the flight) line up; real
               photos flow through once added. -->
          <div class="grid grid-cols-3 gap-2">
            {
              photoHighlights.map(({ f, i }) => (
                <button
                  type="button"
                  data-moment-index={i}
                  class="group/frame relative aspect-square overflow-hidden border border-line/60 transition-colors hover:border-cyan"
                  aria-haspopup="dialog"
                  aria-label={`Open ${f.data.kind === 'video' ? 'film' : 'photo'}: ${f.data.title}`}
                >
                  <span data-media class="absolute inset-0 overflow-hidden">
                    <span
                      class="absolute inset-0 transition-transform duration-500 group-hover/frame:scale-105"
                      style={`background:${momentBackdrop(i)}`}
                      aria-hidden="true"
                    />
                  </span>
                  <span class="absolute bottom-1.5 left-2 font-mono text-[0.55rem] tracking-[0.14em] text-white/70">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                </button>
              ))
            }
          </div>

          <a
            href={withBase('/photography')}
            class="hud-label mt-auto inline-flex w-fit transition-colors hover:text-cyan"
          >
            Open the gallery →
          </a>
        </div>
      </section>

      <section id="timeline" class="mt-6 scroll-mt-16 md:mt-0">
        <a
          href={withBase('/timeline')}
