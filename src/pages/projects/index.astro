---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Section from '../../components/layout/Section.astro';
import ProjectCard from '../../components/projects/ProjectCard.astro';
import Stagger from '../../components/motion/Stagger.astro';
import Reveal from '../../components/motion/Reveal.astro';
import SpecLabel from '../../components/hud/SpecLabel.astro';
import DimensionLine from '../../components/hud/DimensionLine.astro';
import CornerBrackets from '../../components/hud/CornerBrackets.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order || b.data.date.getTime() - a.data.date.getTime(),
);
---

<Base title="Projects" description="Personal engineering projects — DSP, local AI tooling, and reinforcement learning.">
  <header class="relative border-b border-line py-20 md:py-28">
    <div class="container-hud">
      <SpecLabel code="DIV.02" text="PERSONAL PROJECTS" accent />
      <Reveal>
        <h1 class="mt-6 font-display text-5xl font-semibold leading-[0.95] md:text-7xl">
          Things I <span class="text-grad">build</span>
        </h1>
      </Reveal>
      <div class="mt-6 max-w-xl"><DimensionLine value="DSP · LOCAL AI · REINFORCEMENT LEARNING" /></div>
      <Reveal delay={140}>
        <p class="mt-6 max-w-2xl text-lg text-muted">
          Side projects where I chase an idea end-to-end — signal processing, local AI
          tooling, and machine learning. Each one taught me something I've carried back
          into engineering work.
        </p>
      </Reveal>
    </div>
  </header>

  <Section index="A" label="Index" title="Selected work">
    <Stagger class="grid grid-cols-1 gap-5 md:grid-cols-2" gap={70}>
      {
        projects.map((p, i) => (
          <ProjectCard
            index={i + 1}
            href={`/projects/${p.id}`}
            title={p.data.title}
            kind={p.data.kind}
            summary={p.data.summary}
            stack={p.data.stack}
            cover={p.data.cover}
          />
        ))
      }
    </Stagger>

    <!-- FSAE cross-link -->
    <a
      href="/fsae"
      class="group relative mt-5 flex flex-col items-start justify-between gap-4 overflow-hidden border border-line bg-surface/60 p-6 transition-colors hover:border-cyan/50 md:flex-row md:items-center"
    >
      <CornerBrackets size={14} inset={8} color="var(--color-line)" />
      <div>
        <span class="hud-label text-accent">SEE ALSO · FSAE</span>
        <p class="mt-3 max-w-2xl font-display text-xl text-ink">
          The bulk of my engineering lives on the FSAE Electric team — firmware,
          manufacturing, and the driverless stack.
        </p>
      </div>
      <span class="hud-label whitespace-nowrap transition-colors group-hover:text-ink">OPEN FSAE →</span>
    </a>
  </Section>
</Base>
