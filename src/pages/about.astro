---
import Base from '../layouts/Base.astro';
import Section from '../components/layout/Section.astro';
import SkillMatrix from '../components/about/SkillMatrix.astro';
import Reveal from '../components/motion/Reveal.astro';
import Button from '../components/ui/Button.astro';
import Placeholder from '../components/media/Placeholder.astro';
import SpecLabel from '../components/hud/SpecLabel.astro';
import DimensionLine from '../components/hud/DimensionLine.astro';
import CoordinateAxis from '../components/hud/CoordinateAxis.astro';
import { site } from '../config/site';

const now = [
  { k: 'ROLE', v: 'Autonomous Systems Lead, FSAE Electric' },
  { k: 'STUDY', v: 'B.S. Computer Engineering' },
  { k: 'FOCUS', v: 'Perception · Controls · Embedded' },
  { k: 'STATUS', v: 'Open to Summer 2026 internships' },
];
---

<Base title="About" description="About Caleb Pollreis, computer engineering student and FSAE Electric autonomous systems lead.">
  <header class="relative border-b border-line py-20 md:py-28">
    <div class="container-hud">
      <SpecLabel code="DIV.04" text="PROFILE · OPERATOR" accent />
      <Reveal>
        <h1 class="mt-6 font-display text-5xl font-semibold leading-[0.95] md:text-7xl">
          About <span class="text-grad">me</span>
        </h1>
      </Reveal>
      <div class="mt-6 max-w-xl"><DimensionLine value="COMPUTER ENGINEERING × AUTONOMY" /></div>
    </div>
  </header>

  <!-- Bio + portrait -->
  <Section index="A" label="Dossier" title="The short version">
    <div class="grid gap-10 lg:grid-cols-[1fr_360px] lg:gap-16">
      <div class="max-w-2xl space-y-5 text-lg leading-relaxed text-muted">
        <Reveal>
          <p>
            I'm Caleb, a computer engineering student who likes problems that sit right on the
            boundary between hardware and software. On my FSAE Electric team I lead the
            <span class="text-ink">autonomous systems</span> group, but I've worked across the
            whole car: writing firmware for the battery-management system, building and
            validating the HV accumulator, and standing up the driverless stack that now puts
            the car on track by itself.
          </p>
        </Reveal>
        <Reveal delay={100}>
          <p>
            That range is on purpose. The best engineering decisions I've made came from
            understanding the layer above and below the one I was working on, so I chase projects
            that force me to learn the whole stack, from DSP and reinforcement learning to
            high-voltage systems and CAN bus.
          </p>
        </Reveal>
        <Reveal delay={200}>
          <p>
            Away from the workbench I shoot photography: the same eye for systems, pointed at
            light.
          </p>
        </Reveal>
        <Reveal delay={300} class="flex flex-wrap gap-3 pt-4">
          <Button href="/resume.pdf" external>Download résumé</Button>
          <Button href={`mailto:${site.email}`} variant="ghost">Email me</Button>
        </Reveal>
      </div>

      <Reveal direction="left" class="lg:pt-2">
        <div class="relative">
          <Placeholder ratio="3/4" label="PORTRAIT · CP" seed={2} />
          <span class="hud-label absolute -bottom-6 left-0">FIG.PORTRAIT · REPLACE</span>
        </div>
      </Reveal>
    </div>
  </Section>

  <!-- Currently -->
  <Section index="B" label="Status" title="Currently" class="border-y border-line bg-surface/30">
    <dl class="grid grid-cols-1 gap-px overflow-hidden border border-line bg-line sm:grid-cols-2">
      {
        now.map((row) => (
          <div class="flex flex-col gap-2 bg-surface p-6">
            <dt class="hud-label text-accent">{row.k}</dt>
            <dd class="font-display text-lg text-ink">{row.v}</dd>
          </div>
        ))
      }
    </dl>
  </Section>

  <!-- Skills -->
  <Section index="C" label="Capabilities" title="What I work with">
    <div class="mb-10"><CoordinateAxis startLabel="SKILLS" endLabel="MATRIX" /></div>
    <SkillMatrix />
  </Section>

  <!-- Contact -->
  <section class="relative overflow-hidden py-24 md:py-32">
    <div class="container-hud">
      <CoordinateAxis startLabel="COMMS" endLabel="OPEN" class="mb-12 opacity-70" />
      <Reveal>
        <p class="hud-label text-accent">// SAY HELLO</p>
        <h2 class="mt-5 max-w-3xl font-display text-4xl font-semibold leading-tight md:text-6xl">
          Let's talk hardware, autonomy, or anything hard.
        </h2>
      </Reveal>
      <Reveal delay={140} class="mt-10 flex flex-wrap items-center gap-4">
        <Button href={`mailto:${site.email}`}>{site.email}</Button>
        <Button href="/projects" variant="ghost">See my work</Button>
      </Reveal>
    </div>
  </section>
</Base>
