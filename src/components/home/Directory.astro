---
/**
 * Directory - bento grid routing into the site's main sections. Each cell is a
 * framed HUD panel with a spec code, hover lift, and corner brackets.
 */
import Section from '../layout/Section.astro';
import Stagger from '../motion/Stagger.astro';
import CornerBrackets from '../hud/CornerBrackets.astro';
import Placeholder from '../media/Placeholder.astro';
import SlamTrack from '../fsae/SlamTrack.astro';
import { withBase } from '../../config/paths';

const subsystems = ['Firmware', 'Manufacturing', 'Autonomy'];
const projects = ['Music Spectrum Analyzer', 'BMO · Embodied AI Agent', 'Rocket League RL Bot'];
---

<Section index="01" label="Directory" title="Where the work lives">
  <Stagger
    class="grid auto-rows-[minmax(180px,auto)] grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-4"
    gap={70}
  >
    <!-- FSAE - hero cell -->
    <a
      href={withBase('/fsae')}
      data-stagger-item
      class="card-hud group relative flex flex-col justify-between overflow-hidden border border-line bg-surface p-6 transition-all duration-300 hover:border-cyan/60 lg:col-span-2 lg:row-span-2"
    >
      <CornerBrackets size={16} inset={10} color="var(--color-line)" />
      <div class="flex items-start justify-between">
        <span class="hud-label text-accent">01 · FSAE ELECTRIC</span>
        <span class="hud-label opacity-0 transition-opacity group-hover:opacity-100">OPEN →</span>
      </div>
      <!-- live SLAM cone map: the same instrument that headlines /fsae -->
      <div class="relative my-6 grow overflow-hidden border border-line bg-surface" style="min-height:220px">
        <SlamTrack class="absolute inset-0 h-full w-full opacity-75 transition-opacity duration-300 group-hover:opacity-100" />
        <span class="hud-label absolute bottom-3 left-3">SLAM · SIMULATED RUN</span>
        <span class="hud-label absolute right-3 top-3 text-cyan">SIM ●</span>
      </div>
      <div>
        <h3 class="font-display text-2xl text-ink md:text-3xl">Autonomous Systems Lead</h3>
        <p class="mt-2 max-w-md text-sm text-muted">
          Multi-season build log across firmware, manufacturing, and driverless autonomy:
          screenshots, video, and deep-dive write-ups.
        </p>
        <div class="mt-4 flex flex-wrap gap-2">
          {
            subsystems.map((s) => (
              <span class="border border-line px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-wider text-muted">
                {s}
              </span>
            ))
          }
        </div>
      </div>
    </a>

    <!-- Projects -->
    <a
      href={withBase('/projects')}
      data-stagger-item
      class="card-hud group relative flex flex-col justify-between overflow-hidden border border-line bg-surface p-6 transition-all duration-300 hover:border-cyan/60 lg:col-span-2"
    >
      <CornerBrackets size={16} inset={10} color="var(--color-line)" />
      <div class="flex items-start justify-between">
        <span class="hud-label text-accent">02 · PROJECTS</span>
        <span class="hud-label opacity-0 transition-opacity group-hover:opacity-100">OPEN →</span>
      </div>
      <ul class="mt-6 space-y-2.5">
        {
          projects.map((p, i) => (
            <li class="flex items-center gap-3 border-b border-line-soft pb-2.5 last:border-0">
              <span class="font-mono text-[0.65rem] text-faint">{String(i + 1).padStart(2, '0')}</span>
              <span class="font-display text-lg text-ink transition-colors group-hover:text-cyan">{p}</span>
            </li>
          ))
        }
      </ul>
    </a>

    <!-- Photography -->
    <a
      href={withBase('/photography')}
      data-stagger-item
      class="card-hud group relative flex flex-col justify-between overflow-hidden border border-line bg-surface p-6 transition-all duration-300 hover:border-cyan/60"
    >
      <CornerBrackets size={16} inset={10} color="var(--color-line)" />
      <div class="flex items-start justify-between">
        <span class="hud-label text-accent">03 · PHOTO</span>
      </div>
      <div class="mt-5 grow">
        <Placeholder ratio="4/3" label="F/2.8 · 1/500" seed={1} class="h-full" />
      </div>
      <h3 class="mt-4 font-display text-xl text-ink">Photography</h3>
    </a>

    <!-- About -->
    <a
      href={withBase('/about')}
      data-stagger-item
      class="card-hud group relative flex flex-col justify-between overflow-hidden border border-line bg-surface p-6 transition-all duration-300 hover:border-cyan/60"
    >
      <CornerBrackets size={16} inset={10} color="var(--color-line)" />
      <span class="hud-label text-accent">04 · ABOUT</span>
      <div>
        <h3 class="mt-6 font-display text-xl text-ink">Profile &amp; contact</h3>
        <p class="mt-2 text-sm text-muted">Bio, stack, resume.</p>
      </div>
      <span class="hud-label mt-4 transition-colors group-hover:text-cyan">CONNECT →</span>
    </a>

    <!-- Timeline - full-width spine banner -->
    <a
      href={withBase('/timeline')}
      data-stagger-item
      class="card-hud group relative flex min-h-[150px] flex-col justify-center overflow-hidden border border-line bg-surface p-6 transition-all duration-300 hover:border-cyan/60 sm:col-span-2 lg:col-span-4"
    >
      <CornerBrackets size={16} inset={10} color="var(--color-line)" />
      <!-- decorative spine sweep (the /timeline channel on its side), drawn in on scroll -->
      <svg
        viewBox="0 0 900 150"
        preserveAspectRatio="xMidYMid slice"
        class="absolute inset-0 h-full w-full opacity-50 transition-opacity duration-300 group-hover:opacity-90"
        fill="none"
        aria-hidden="true"
        data-draw
      >
        <path d="M30 75 H870" stroke="var(--color-cyan)" stroke-opacity="0.35" stroke-width="1" />
        <g stroke="var(--color-cyan)" stroke-opacity="0.25" stroke-width="1">
          {
            [140, 265, 390, 520, 650, 780].map((x, i) => (
              <path d={`M${x} 75 V${i % 2 === 0 ? 42 : 108}`} />
            ))
          }
        </g>
        <g fill="var(--color-cyan)">
          {
            [30, 140, 265, 390, 520, 650, 780, 870].map((x, i) => {
              const s = i % 3 === 1 ? 5 : 3.5;
              const y = 75;
              return (
                <path
                  d={`M${x} ${y - s} L${x + s * 0.32} ${y - s * 0.32} L${x + s} ${y} L${x + s * 0.32} ${y + s * 0.32} L${x} ${y + s} L${x - s * 0.32} ${y + s * 0.32} L${x - s} ${y} L${x - s * 0.32} ${y - s * 0.32} Z`}
                  fill-opacity={i % 3 === 1 ? 0.9 : 0.55}
                />
              );
            })
          }
        </g>
      </svg>
      <div class="relative flex flex-wrap items-center justify-between gap-4">
        <div>
          <span class="hud-label text-accent">05 · TIMELINE</span>
          <h3 class="mt-2 font-display text-2xl text-ink md:text-3xl">A universe of moments</h3>
          <p class="mt-1 max-w-md text-sm text-muted">
            Every milestone since 2022 on one line, with the year keeping pace as you scroll.
          </p>
        </div>
        <span class="hud-label transition-colors group-hover:text-cyan">EXPLORE →</span>
      </div>
    </a>

    <!-- Photography - full-width banner, mirrors the timeline treatment -->
    <a
      href={withBase('/photography')}
      data-stagger-item
      class="card-hud group relative flex min-h-[150px] flex-col justify-center overflow-hidden border border-line bg-surface p-6 transition-all duration-300 hover:border-cyan/60 sm:col-span-2 lg:col-span-4"
    >
      <CornerBrackets size={16} inset={10} color="var(--color-line)" />
      <div class="relative flex flex-wrap items-center justify-between gap-4">
        <div>
          <span class="hud-label text-accent">06 · OPTICS</span>
          <h3 class="mt-2 font-display text-2xl text-ink md:text-3xl">Through the lens</h3>
          <p class="mt-1 max-w-md text-sm text-muted">
            Frames from the field: 35mm to 85mm, everything the shutter caught between builds.
          </p>
        </div>
        <span class="hud-label transition-colors group-hover:text-cyan">VIEW GALLERY →</span>
      </div>
    </a>
  </Stagger>
</Section>
