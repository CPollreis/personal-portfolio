---
/**
 * Hero - full-height HUD landing over a looping background video of the car
 * (MIT FSAE style: footage behind, text in focus). Drop the clip at
 * public/videos/hero-loop.mp4; until then the layer is simply black.
 * Reticle + scramble tagline + dimensioned name block on top. Playback across
 * ClientRouter swaps is handled globally by src/scripts/footage.ts.
 */
import Reticle from '../hud/Reticle.astro';
import SpecLabel from '../hud/SpecLabel.astro';
import CoordinateAxis from '../hud/CoordinateAxis.astro';
import DimensionLine from '../hud/DimensionLine.astro';
import ScrambleText from '../motion/ScrambleText.astro';
import Reveal from '../motion/Reveal.astro';
import Button from '../ui/Button.astro';
import { site } from '../../config/site';
import { withBase } from '../../config/paths';

/* Telemetry ticker feed: real facts only, styled as readouts. PACK/CAN values
   are the car's actual figures; the rest is verifiable from the resume. */
const feed = [
  'PACK 380V',
  'CAN 500K',
  'DRIVERLESS TARGET · 2028',
  'C++ / ROS 2',
  'NVIDIA JETSON ORIN',
  'BMS · PM100DX',
  'STM32 · FREERTOS',
  '$30K SENSORS SPONSORED',
  'UMSAE FORMULA ELECTRIC',
  'LAT 49.90°N',
  'LON 97.14°W',
];
---

<section class="relative flex min-h-[100dvh] flex-col justify-center overflow-hidden pt-16">
  <!-- background footage layer -->
  <div class="absolute inset-0" aria-hidden="true">
    <video
      data-header-video
      class="h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      tabindex="-1"
    >
      <!-- webm first: Firefox's macOS H.264 decoder can fail after client-side
           navigation (see src/scripts/footage.ts); VP9 decodes in software -->
      <source src={withBase('/videos/hero-loop-web.webm')} type="video/webm" />
      <source src={withBase('/videos/hero-loop-web.mp4')} type="video/mp4" />
    </video>
    <!-- dimming + focus gradient so the type stays legible over footage -->
    <div class="absolute inset-0 bg-bg/55"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-bg/80 via-bg/35 to-bg/20"></div>
    <!-- fade the footage into the page background so sections meet seamlessly -->
    <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-bg to-transparent"></div>
  </div>

  <!-- ambient accent glow over the footage -->
  <div class="glow-header pointer-events-none absolute inset-0" aria-hidden="true"></div>

  <div class="container-hud relative">
    <!-- top status row -->
    <div class="mb-8 flex items-center gap-4">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan opacity-60"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-cyan"></span>
      </span>
      <span class="hud-label text-ink">PORTFOLIO</span>
      <span class="h-px w-10 bg-line"></span>
      <span class="hud-label">U OF MANITOBA · GRAD 2028</span>
    </div>

    <div class="grid items-center gap-10 lg:grid-cols-[1fr_auto]">
      <div>
        <div data-reveal="clip">
          <h1 class="font-display text-[3.25rem] font-semibold leading-[0.95] tracking-tight sm:text-7xl lg:text-8xl">
            Caleb
            <br />
            <span class="text-grad">Pollreis</span>
          </h1>
        </div>

        <div class="mt-6 max-w-xl">
          <DimensionLine value={site.role} />
        </div>

        <Reveal delay={160}>
          <p class="mt-6 max-w-lg text-lg text-muted">
            <ScrambleText as="span" text={site.tagline} />
          </p>
        </Reveal>

        <!-- the 30-second answers: who, where, what, when -->
        <Reveal delay={220}>
          <p class="mt-4 max-w-lg text-sm leading-relaxed text-muted/90">
            {site.intro}
          </p>
          <p class="mt-4 flex items-center gap-2.5">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan opacity-60"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-cyan"></span>
            </span>
            <span class="hud-label text-ink">{site.availability}</span>
          </p>
        </Reveal>

        <Reveal delay={300} class="mt-9">
          <div class="inline-grid grid-cols-1 gap-3 sm:grid-cols-2">
            <Button href="/fsae">View FSAE work</Button>
            <Button href="/projects" variant="ghost">Personal projects</Button>
            <Button href={`mailto:${site.email}`} variant="ghost">Get in touch</Button>
            <Button href="/resume.pdf" variant="ghost" external>Download resume</Button>
          </div>
        </Reveal>
      </div>

      <!-- Reticle instrument -->
      <div class="relative hidden justify-self-end lg:block">
        <Reticle size={260} />
        <span class="hud-label absolute -bottom-2 left-1/2 -translate-x-1/2">TRACKING · LOCK</span>
      </div>
    </div>

    <div class="mt-16">
      <CoordinateAxis startLabel="00.0" endLabel="SCROLL ↓" />
    </div>
    <SpecLabel class="mt-6" code="FIG.00" text="INDEX · COMPUTER ENGINEERING × AUTONOMY" />
  </div>

  <!-- live telemetry ticker pinned to the hero's lower edge -->
  <div class="ticker absolute inset-x-0 bottom-0 border-t border-line-soft bg-bg/40 py-2.5 backdrop-blur-sm" aria-hidden="true">
    <div class="ticker-track">
      {
        [0, 1].map(() => (
          <span class="flex shrink-0 items-center">
            {feed.map((item) => (
              <span class="flex items-center">
                <span class="hud-label px-5 text-muted">{item}</span>
                <span class="h-1 w-1 rounded-full bg-accent/70" />
              </span>
            ))}
          </span>
        ))
      }
    </div>
  </div>
</section>
