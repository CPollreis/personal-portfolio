---
/**
 * Telemetry - animated stat row over a scroll-drawn circuit trace. Numbers are
 * placeholders; tune once real figures are known.
 */
import DataReadout from '../hud/DataReadout.astro';
import CircuitTrace from '../hud/CircuitTrace.astro';
import SpecLabel from '../hud/SpecLabel.astro';

/* Verified against the resume: joined Sept 2022; 10+ members led as Software
   System Lead and as Autonomous Systems Lead; ~$30k sponsored driverless
   hardware; six personal projects on the resume. */
const stats = [
  { label: 'Seasons on team', value: 4, unit: 'yrs' },
  { label: 'Engineers led', value: 10, suffix: '+', unit: 'members' },
  { label: 'Sponsored hardware', value: 30, suffix: 'k', unit: 'secured' },
  { label: 'Personal projects', value: 6, unit: 'builds' },
];
---

<section class="relative overflow-hidden py-16 md:py-20">
  <div class="pointer-events-none absolute -right-10 top-1/2 hidden w-[420px] -translate-y-1/2 text-accent opacity-30 lg:block">
    <CircuitTrace mode="scroll" />
  </div>
  <div class="container-hud">
    <SpecLabel code="TLM" text="SYSTEM TELEMETRY" accent class="mb-10" />
    <div class="grid grid-cols-2 gap-x-6 gap-y-10 lg:grid-cols-4">
      {
        stats.map((s) => (
          <DataReadout label={s.label} value={s.value} suffix={s.suffix ?? ''} unit={s.unit} />
        ))
      }
    </div>
  </div>
</section>
