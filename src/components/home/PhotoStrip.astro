---
/**
 * PhotoStrip — horizontal preview reel linking to the photography gallery.
 * Placeholders swap for real frames in Phase 6.
 */
import Section from '../layout/Section.astro';
import Stagger from '../motion/Stagger.astro';
import Placeholder from '../media/Placeholder.astro';

const frames = [
  { label: 'IMG_0142 · 35MM · F/1.8', ratio: '3/4' },
  { label: 'IMG_0288 · 85MM · F/2.0', ratio: '4/3' },
  { label: 'IMG_0391 · 24MM · F/8.0', ratio: '3/4' },
  { label: 'IMG_0455 · 50MM · F/1.4', ratio: '4/3' },
];
---

<Section index="03" label="Optics" title="Through the lens">
  <Stagger class="grid grid-cols-2 gap-4 lg:grid-cols-4" gap={60}>
    {
      frames.map((f, i) => (
        <a href="/photography" data-stagger-item class="block">
          <Placeholder ratio={f.ratio} label={f.label} seed={i} />
        </a>
      ))
    }
  </Stagger>
  <div class="mt-8">
    <a href="/photography" class="link-hud font-mono text-xs uppercase tracking-widest text-muted hover:text-ink">
      View full gallery →
    </a>
  </div>
</Section>
