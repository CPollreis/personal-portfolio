---
/**
 * ProjectCard — personal project preview with index, kind, stack, and cover.
 */
import { Image } from 'astro:assets';
import Placeholder from '../media/Placeholder.astro';
import CornerBrackets from '../hud/CornerBrackets.astro';

interface Props {
  index: number;
  href: string;
  title: string;
  kind: string;
  summary: string;
  stack: string[];
  cover?: ImageMetadata;
}
const { index, href, title, kind, summary, stack, cover } = Astro.props;
const idx = String(index).padStart(2, '0');
---

<a
  href={href}
  data-stagger-item
  class="group relative flex flex-col overflow-hidden border border-line bg-surface transition-colors duration-300 hover:border-cyan/50"
>
  <div class="relative overflow-hidden">
    {
      cover ? (
        <Image
          src={cover}
          alt={title}
          widths={[400, 800]}
          sizes="(min-width: 768px) 50vw, 100vw"
          class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
        />
      ) : (
        <Placeholder ratio="16/10" label={`PROJ.${idx} · ${kind}`} seed={index} />
      )
    }
  </div>
  <div class="flex grow flex-col p-6">
    <div class="flex items-center justify-between">
      <span class="font-mono text-xs text-accent">{idx}</span>
      <span class="hud-label">{kind}</span>
    </div>
    <h3 class="mt-4 font-display text-2xl text-ink transition-colors group-hover:text-cyan">{title}</h3>
    <p class="mt-2 grow text-sm text-muted">{summary}</p>
    <div class="mt-5 flex flex-wrap gap-1.5">
      {
        stack.map((s) => (
          <span class="border border-line px-2 py-0.5 font-mono text-[0.6rem] uppercase tracking-wider text-muted">
            {s}
          </span>
        ))
      }
    </div>
    <span class="hud-label mt-6 transition-colors group-hover:text-ink">VIEW PROJECT →</span>
  </div>
  <CornerBrackets size={12} inset={6} color="var(--color-line)" />
</a>
