---
/**
 * Constellation - the interactive "personal universe" timeline.
 *
 * Each year is a constellation of star nodes (one per moment) joined by
 * glowing edges, drifting over a parallax canvas starfield with faint
 * accent-triad nebulae. The camera pans and zooms over an infinite-feeling
 * world; clicking a star flies the camera in and blooms a detail card out
 * of the star itself.
 *
 * Rendering split:
 *   canvas  -> starfield, nebulae, constellation edges (cheap, redrawn per frame)
 *   DOM     -> star buttons, year numerals, detail card (accessible, crisp text)
 *
 * All world-space layout (constellation shapes, edges, bounds) is computed at
 *  build time from src/config/timeline.ts and shipped as JSON; the client
 * engine only runs the camera.
 */
import { timeline, kindLabels } from '../../config/timeline';
import CornerBrackets from '../hud/CornerBrackets.astro';

/* ---- constellation shape templates (relative world offsets, date order) ---- */
const TEMPLATES: [number, number][][] = [
  // lyre: a low sweep rising to a bright tail
  [[-280, 60], [-140, -90], [20, -30], [150, -140], [290, -40], [190, 130]],
  // cassiopeia-style zigzag
  [[-300, -30], [-160, 90], [-10, -70], [130, 80], [280, -40], [90, 190]],
  // rising arc with a dropped anchor star
  [[-290, 110], [-170, -30], [-20, -120], [150, -90], [270, 20], [330, 160]],
  // dipper: cup plus handle
  [[-300, 20], [-150, -50], [0, -20], [140, 40], [250, 150], [80, 180]],
  // kite
  [[-240, -90], [-60, -150], [120, -70], [190, 80], [10, 160], [-190, 90]],
];

/* ---- year cluster anchors: a gentle wave marching left to right ---- */
const ANCHORS: [number, number][] = [
  [0, 260],
  [950, -40],
  [1900, 220],
  [2850, -100],
  [3800, 120],
];

const MONTHS = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', 'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC'];
function dateLabel(iso: string): string {
  const d = new Date(iso + 'T00:00:00Z');
  return `${MONTHS[d.getUTCMonth()]} ${String(d.getUTCDate()).padStart(2, '0')} ${d.getUTCFullYear()}`;
}

interface NodeOut {
  id: string;
  x: number;
  y: number;
  kind: string;
  weight: number;
  dateLabel: string;
  title: string;
  why: string;
  year: number;
  media?: { type: string; src?: string; alt: string };
}

const nodes: NodeOut[] = [];
const edges: [number, number, number, number, number][] = []; // x1 y1 x2 y2 dash
const yearsOut: { year: number; theme: string; x: number; y: number }[] = [];

timeline.forEach((yr, yi) => {
  const [ax, ay] = ANCHORS[yi % ANCHORS.length];
  const tpl = TEMPLATES[yi % TEMPLATES.length];
  const evs = [...yr.events].sort((a, b) => a.date.localeCompare(b.date));
  const placed = evs.map((ev, i) => {
    const [dx, dy] = tpl[i % tpl.length];
    return { ev, x: ax + dx, y: ay + dy };
  });
  placed.forEach((p) => {
    nodes.push({
      id: p.ev.id,
      x: p.x,
      y: p.y,
      kind: p.ev.kind,
      weight: p.ev.weight ?? 1,
      dateLabel: dateLabel(p.ev.date),
      title: p.ev.title,
      why: p.ev.why,
      year: yr.year,
      media: p.ev.media,
    });
  });
  // constellation polyline within the year
  for (let i = 0; i < placed.length - 1; i++) {
    edges.push([placed[i].x, placed[i].y, placed[i + 1].x, placed[i + 1].y, 0]);
  }
  yearsOut.push({ year: yr.year, theme: yr.theme, x: ax, y: ay });
});

// dashed thread connecting the last star of each year to the first of the next
timeline.forEach((yr, yi) => {
  if (yi === timeline.length - 1) return;
  const a = nodes.filter((n) => n.year === yr.year).at(-1)!;
  const b = nodes.filter((n) => n.year === timeline[yi + 1].year)[0];
  edges.push([a.x, a.y, b.x, b.y, 1]);
});

const xs = nodes.map((n) => n.x);
const ys = nodes.map((n) => n.y);
const PAD = 340;
const bounds = {
  minX: Math.min(...xs) - PAD,
  minY: Math.min(...ys) - PAD,
  maxX: Math.max(...xs) + PAD,
  maxY: Math.max(...ys) + PAD,
};

const payload = { nodes, edges, years: yearsOut, bounds, kindLabels };
---

<section
  id="constellation"
  class="relative h-[100dvh] w-full overflow-hidden bg-bg"
  data-band="far"
  aria-label="Interactive timeline: a constellation map of moments since 2022"
>
  <canvas id="tl-canvas" class="absolute inset-0 h-full w-full" aria-hidden="true"></canvas>

  <!-- world layer: year numerals + one star button per moment -->
  <div id="tl-world" class="absolute inset-0" aria-label="Moments">
    {
      yearsOut.map((y) => (
        <div class="tl-year" data-year={y.year} aria-hidden="true">
          <span class="tl-year-num">{y.year}</span>
          <span class="tl-year-theme hud-label">{y.theme}</span>
        </div>
      ))
    }
    {
      nodes.map((n, i) => (
        <button
          type="button"
          class="tl-star"
          data-id={n.id}
          data-kind={n.kind}
          data-w={n.weight}
          style={`--i:${i}`}
          aria-label={`${n.title}, ${n.dateLabel}. View details.`}
          aria-expanded="false"
        >
          <span class="tl-halo" aria-hidden="true"></span>
          <span class="tl-core" aria-hidden="true"></span>
          <span class="tl-label" aria-hidden="true">
            <span class="tl-label-date">{n.dateLabel}</span>
            <span class="tl-label-title">{n.title}</span>
          </span>
        </button>
      ))
    }
  </div>

  <!-- detail card: populated + anchored to the active star by the engine -->
  <aside id="tl-card" class="tl-card" hidden>
    <div
      class="tl-card-inner"
      role="dialog"
      aria-modal="false"
      aria-labelledby="tl-card-title"
      aria-describedby="tl-card-why"
    >
      <CornerBrackets size={14} inset={8} color="var(--color-line)" />
      <div class="tl-card-head">
        <span id="tl-card-kind" class="hud-label"></span>
        <span id="tl-card-date" class="hud-label tabular" style="color: var(--color-cyan)"></span>
      </div>
      <figure id="tl-card-media" class="tl-card-media"></figure>
      <h2 id="tl-card-title" class="tl-card-title"></h2>
      <p id="tl-card-why" class="tl-card-why"></p>
      <div class="tl-card-foot">
        <button type="button" id="tl-card-close" class="tl-card-close">Close</button>
        <span class="hud-label">Esc returns</span>
      </div>
    </div>
  </aside>

  <!-- HUD chrome -->
  <div class="tl-ui pointer-events-none absolute inset-x-0 bottom-0 z-20 flex items-end justify-between p-4 md:p-6">
    <div class="hidden flex-col gap-2 sm:flex">
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        <span class="tl-legend" style="--star-c: #fafafa">Milestone</span>
        <span class="tl-legend" style="--star-c: var(--color-cyan)">FSAE</span>
        <span class="tl-legend" style="--star-c: var(--color-accent)">Project</span>
        <span class="tl-legend" style="--star-c: var(--color-indigo)">Photo</span>
      </div>
      <span class="hud-label">Drag to pan · Scroll or pinch to zoom · Click a star</span>
    </div>
    <div class="pointer-events-auto flex flex-col gap-px border border-line bg-bg/70 backdrop-blur-sm">
      <button type="button" class="tl-ctrl" id="tl-zoom-in" aria-label="Zoom in">+</button>
      <button type="button" class="tl-ctrl" id="tl-zoom-out" aria-label="Zoom out">−</button>
      <button type="button" class="tl-ctrl" id="tl-reset" aria-label="Reset view">⌂</button>
    </div>
  </div>
  <div class="tl-ui pointer-events-none absolute right-4 top-20 z-20 hidden md:right-6 md:block">
    <span id="tl-readout" class="hud-label tabular">Z 0.00 · X +0000 · Y +0000</span>
  </div>

  <script is:inline type="application/json" id="tl-data" set:html={JSON.stringify(payload)} />
</section>

<style is:global>
  /* ---------- world layer ---------- */
  #constellation {
    touch-action: pan-y; /* phones: vertical swipe scrolls the page, horizontal pans the map */
    --nk: 1;
  }
  @media (min-width: 1024px) {
    #constellation { touch-action: none; }
  }
  #tl-world {
    opacity: 0;
  }
  #constellation[data-ready] #tl-world {
    opacity: 1;
    transition: opacity 600ms var(--ease-out-hud);
  }

  #constellation .tl-year {
    position: absolute;
    left: 0;
    top: 0;
    /* the engine composes translate3d(sx,sy) scale(k) translate(-50%,-50%);
       that math assumes the transform pivots at the element's top-left */
    transform-origin: 0 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    pointer-events: none;
    user-select: none;
    will-change: transform;
  }
  #constellation .tl-year-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 230px;
    line-height: 1;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--color-line) 92%, var(--color-accent));
    opacity: 0.7;
  }
  #constellation .tl-year-theme {
    font-size: 1.6rem;
    letter-spacing: 0.55em;
    color: var(--color-faint);
  }

  /* ---------- star nodes ---------- */
  #constellation .tl-star {
    position: absolute;
    left: 0;
    top: 0;
    width: 44px;
    height: 44px;
    margin: -22px 0 0 -22px;
    padding: 0;
    border: 0;
    background: none;
    display: grid;
    place-items: center;
    will-change: transform;
    opacity: 0;
    transition: opacity 500ms var(--ease-out-hud);
    transition-delay: calc(var(--i, 0) * 45ms);
    --star-c: #fafafa;
  }
  #constellation[data-ready] .tl-star { opacity: 1; }
  #constellation .tl-star[data-kind='fsae'] { --star-c: var(--color-cyan); }
  #constellation .tl-star[data-kind='project'] { --star-c: var(--color-accent); }
  #constellation .tl-star[data-kind='photo'] { --star-c: color-mix(in srgb, var(--color-indigo) 72%, #b1a2ff); }

  #constellation .tl-halo {
    position: absolute;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: radial-gradient(circle, color-mix(in srgb, var(--star-c) 40%, transparent), transparent 68%);
    opacity: 0.55;
    transform: scale(var(--nk));
    transition: opacity var(--dur-base) var(--ease-out-hud);
  }
  #constellation .tl-core {
    position: relative;
    width: 12px;
    height: 12px;
    background: color-mix(in srgb, var(--star-c) 85%, #ffffff);
    clip-path: polygon(50% 0, 61% 39%, 100% 50%, 61% 61%, 50% 100%, 39% 61%, 0 50%, 39% 39%);
    transform: scale(var(--nk));
    filter: drop-shadow(0 0 6px color-mix(in srgb, var(--star-c) 80%, transparent));
    transition: transform var(--dur-base) var(--ease-out-hud);
  }
  #constellation .tl-star[data-w='2'] .tl-core { width: 19px; height: 19px; }
  #constellation .tl-star[data-w='2'] .tl-halo {
    width: 58px;
    height: 58px;
    opacity: 0.7;
  }
  #constellation .tl-star:hover .tl-halo,
  #constellation .tl-star:focus-visible .tl-halo { opacity: 1; }
  #constellation .tl-star:hover .tl-core,
  #constellation .tl-star:focus-visible .tl-core { transform: scale(calc(var(--nk) * 1.35)); }
  #constellation .tl-star[data-active] .tl-core { transform: scale(calc(var(--nk) * 1.45)); }
  #constellation .tl-star[data-active] .tl-halo {
    opacity: 1;
    animation: tl-pulse 2.2s var(--ease-out-hud) infinite;
  }
  @keyframes tl-pulse {
    0% { transform: scale(var(--nk)); opacity: 1; }
    100% { transform: scale(calc(var(--nk) * 2)); opacity: 0; }
  }

  /* labels: what shows depends on the zoom band on #constellation */
  #constellation .tl-label {
    position: absolute;
    top: calc(50% + 14px * var(--nk) + 6px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    width: max-content;
    max-width: 190px;
    text-align: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 350ms var(--ease-out-hud);
    text-shadow: 0 1px 8px rgba(9, 9, 11, 0.9);
  }
  #constellation .tl-label-title {
    font-family: var(--font-display);
    font-size: 0.8rem;
    line-height: 1.25;
    color: var(--color-ink);
  }
  #constellation .tl-label-date {
    display: none;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, var(--star-c) 70%, var(--color-muted));
  }
  #constellation[data-band='mid'] .tl-label,
  #constellation[data-band='near'] .tl-label { opacity: 1; }
  #constellation[data-band='far'] .tl-star[data-w='2'] .tl-label { opacity: 0.9; }
  #constellation[data-band='near'] .tl-label-date { display: block; }
  #constellation .tl-star:hover .tl-label,
  #constellation .tl-star:focus-visible .tl-label { opacity: 1; }

  /* ---------- detail card ---------- */
  #tl-card {
    position: absolute;
    left: 0;
    top: 0;
    z-index: 30;
    width: min(360px, 88vw);
    will-change: transform;
  }
  #tl-card .tl-card-inner {
    position: relative;
    border: 1px solid var(--color-line);
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    padding: 1.1rem 1.2rem 1rem;
    transform: scale(0.72);
    opacity: 0;
    transition:
      transform 480ms var(--ease-out-hud),
      opacity 300ms var(--ease-out-hud);
  }
  #tl-card.open .tl-card-inner {
    transform: scale(1);
    opacity: 1;
  }
  #tl-card .tl-card-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.8rem;
  }
  #tl-card .tl-card-media {
    margin: 0 0 0.85rem;
    border: 1px solid var(--color-line);
    overflow: hidden;
  }
  #tl-card .tl-card-media:empty { display: none; }
  #tl-card .tl-card-media img,
  #tl-card .tl-card-media video {
    display: block;
    width: 100%;
    max-height: 200px;
    object-fit: cover;
  }
  #tl-card .tl-media-pending {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem;
    min-height: 110px;
    justify-content: flex-end;
    background:
      radial-gradient(120% 130% at 20% 0%, color-mix(in srgb, var(--color-indigo) 16%, transparent), transparent 60%),
      radial-gradient(120% 130% at 90% 100%, color-mix(in srgb, var(--color-cyan) 10%, transparent), transparent 60%),
      var(--color-raised);
  }
  #tl-card .tl-media-pending .hud-label { color: var(--color-faint); }
  #tl-card .tl-media-pending p {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--color-muted);
    font-style: italic;
  }
  #tl-card .tl-card-title {
    font-size: 1.3rem;
    color: var(--color-ink);
    margin: 0 0 0.5rem;
  }
  #tl-card .tl-card-why {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-muted);
  }
  #tl-card .tl-card-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-line-soft);
  }
  #tl-card .tl-card-close {
    border: 1px solid var(--color-line);
    background: none;
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.45rem 0.9rem;
    transition: border-color var(--dur-micro) var(--ease-out-hud);
  }
  #tl-card .tl-card-close:hover { border-color: var(--color-cyan); }

  /* phones: the card docks as a bottom sheet instead of anchoring to the star */
  @media (max-width: 639px) {
    #tl-card {
      position: fixed;
      inset: auto 0 0 0;
      width: auto;
      transform: none !important;
      z-index: 45;
    }
    #tl-card .tl-card-inner {
      border-left: 0;
      border-right: 0;
      transform: translateY(28px);
      transform-origin: center bottom !important;
      padding-bottom: max(1rem, env(safe-area-inset-bottom));
    }
    #tl-card.open .tl-card-inner { transform: translateY(0); }
  }

  /* ---------- HUD chrome ---------- */
  #constellation .tl-legend {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  #constellation .tl-legend::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--star-c);
    clip-path: polygon(50% 0, 61% 39%, 100% 50%, 61% 61%, 50% 100%, 39% 61%, 0 50%, 39% 39%);
  }
  #constellation .tl-ctrl {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border: 0;
    background: none;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 1rem;
    transition: color var(--dur-micro) var(--ease-out-hud), background var(--dur-micro) var(--ease-out-hud);
  }
  #constellation .tl-ctrl + .tl-ctrl { border-top: 1px solid var(--color-line); }
  #constellation .tl-ctrl:hover {
    color: var(--color-cyan);
    background: color-mix(in srgb, var(--color-cyan) 8%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    #constellation .tl-star[data-active] .tl-halo { animation: none; }
  }
</style>

<script>
  /**
   * Constellation camera engine. World layout arrives via the embedded JSON;
   * this module owns: camera pan/zoom (drag, wheel, pinch, keys, buttons),
   * canvas rendering (starfield, nebulae, edges), DOM node positioning,
   * fly-to + detail-card bloom, and ClientRouter-safe lifecycle.
   */

  interface TLNode {
    id: string;
    x: number;
    y: number;
    kind: string;
    weight: number;
    dateLabel: string;
    title: string;
    why: string;
    year: number;
    media?: { type: string; src?: string; alt: string };
  }
  interface TLData {
    nodes: TLNode[];
    edges: [number, number, number, number, number][];
    years: { year: number; theme: string; x: number; y: number }[];
    bounds: { minX: number; minY: number; maxX: number; maxY: number };
    kindLabels: Record<string, string>;
  }

  function mulberry32(seed: number) {
    let a = seed >>> 0;
    return () => {
      a |= 0;
      a = (a + 0x6d2b79f5) | 0;
      let t = Math.imul(a ^ (a >>> 15), 1 | a);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  const easeOutQuart = (p: number) => 1 - Math.pow(1 - p, 4);

  function initConstellation() {
    const rootEl = document.getElementById('constellation');
    if (!rootEl || rootEl.dataset.bound) return;
    // alias so TS keeps the non-null narrowing inside the nested closures below
    const root: HTMLElement = rootEl;
    root.dataset.bound = '1';

    const data: TLData = JSON.parse(document.getElementById('tl-data')!.textContent!);
    const canvas = document.getElementById('tl-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const world = document.getElementById('tl-world')!;
    const card = document.getElementById('tl-card')!;
    const cardInner = card.querySelector<HTMLElement>('.tl-card-inner')!;
    const readout = document.getElementById('tl-readout')!;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const btns = new Map<string, HTMLButtonElement>();
    world.querySelectorAll<HTMLButtonElement>('.tl-star').forEach((b) => btns.set(b.dataset.id!, b));
    const yearEls = Array.from(world.querySelectorAll<HTMLElement>('.tl-year'));
    const byId = new Map(data.nodes.map((n) => [n.id, n]));
    const { bounds } = data;
    const cx0 = (bounds.minX + bounds.maxX) / 2;
    const cy0 = (bounds.minY + bounds.maxY) / 2;
    const bw = bounds.maxX - bounds.minX;
    const bh = bounds.maxY - bounds.minY;

    /* ---- camera ---- */
    let W = 0;
    let H = 0;
    const cam = { x: cx0, y: cy0, k: 0.3 };
    const overviewK = () => Math.min(W / bw, H / bh) * 0.84;
    const focusK = () => Math.min(W / 1500, H / 1350);
    const homeK = () => (W >= 700 ? overviewK() : Math.max(overviewK(), focusK()));
    const homeC = () => (W >= 700 ? { x: cx0, y: cy0 } : { x: data.years[0].x, y: data.years[0].y });
    const flyK = () => Math.max(homeK() * 2.6, Math.min(W / 1250, H / 950, 2.2));
    const minK = () => Math.min(overviewK(), homeK()) * 0.7;
    const maxK = () => flyK() * 1.6;
    const clampCam = () => {
      cam.k = Math.min(Math.max(cam.k, minK()), maxK());
      cam.x = Math.min(Math.max(cam.x, bounds.minX), bounds.maxX);
      cam.y = Math.min(Math.max(cam.y, bounds.minY), bounds.maxY);
    };
    const w2sX = (wx: number) => (wx - cam.x) * cam.k + W / 2;
    const w2sY = (wy: number) => (wy - cam.y) * cam.k + H / 2;

    /* ---- starfield (generated once, deterministic) ---- */
    const rnd = mulberry32(20220907);
    interface BgStar { x: number; y: number; s: number; a: number; ph: number; sp: number; c: string; glint: boolean }
    const layers: { d: number; stars: BgStar[] }[] = [
      { d: 0.22, stars: [] },
      { d: 0.45, stars: [] },
      { d: 0.75, stars: [] },
    ];
    const counts = [190, 140, 95];
    layers.forEach((layer, li) => {
      const spanX = (bw / 2 + 900) / layer.d;
      const spanY = (bh / 2 + 900) / layer.d;
      for (let i = 0; i < counts[li]; i++) {
        const r = rnd();
        layer.stars.push({
          x: cx0 + (rnd() * 2 - 1) * spanX,
          y: cy0 + (rnd() * 2 - 1) * spanY,
          s: 0.5 + rnd() * (0.7 + li * 0.5),
          a: 0.1 + rnd() * (0.16 + li * 0.1),
          ph: rnd() * Math.PI * 2,
          sp: 0.4 + rnd() * 1.4,
          c: r < 0.8 ? '#dbe4ff' : r < 0.92 ? '#9fd8ef' : '#b7a6ff',
          glint: li === 2 && rnd() > 0.82,
        });
      }
    });
    const NEBULA_RGB = [
      [74, 37, 235],
      [37, 99, 235],
      [37, 198, 235],
    ];
    const nebulae = data.years.map((y, i) => ({
      x: y.x + (i % 2 ? -180 : 220),
      y: y.y - 120 + (i % 2 ? 200 : -40),
      r: 560 + (i % 3) * 150,
      c: NEBULA_RGB[i % 3],
    }));

    /* ---- tween ---- */
    let tween: {
      fx: number; fy: number; fk: number;
      tx: number; ty: number; tk: number;
      t0: number; dur: number; done?: () => void;
    } | null = null;
    let dirty = true;
    function tweenTo(t: { x: number; y: number; k: number }, dur: number, done?: () => void) {
      if (reduced || dur <= 0) {
        cam.x = t.x; cam.y = t.y; cam.k = t.k;
        clampCam();
        dirty = true;
        done?.();
        return;
      }
      tween = { fx: cam.x, fy: cam.y, fk: cam.k, tx: t.x, ty: t.y, tk: t.k, t0: performance.now(), dur, done };
    }
    const cancelTween = () => { tween = null; };

    /* ---- card ---- */
    let activeId: string | null = null;
    let prevCam: { x: number; y: number; k: number } | null = null;
    let hideTimer = 0;
    const isSheet = () => W < 640;

    function populateCard(n: TLNode) {
      (document.getElementById('tl-card-kind')!).textContent =
        `${data.kindLabels[n.kind] ?? n.kind} · ${n.year}`;
      (document.getElementById('tl-card-date')!).textContent = n.dateLabel;
      (document.getElementById('tl-card-title')!).textContent = n.title;
      (document.getElementById('tl-card-why')!).textContent = n.why;
      const fig = document.getElementById('tl-card-media')!;
      fig.textContent = '';
      if (!n.media) return;
      if (n.media.src) {
        if (n.media.type === 'video') {
          const v = document.createElement('video');
          v.src = n.media.src;
          v.controls = true;
          v.muted = true;
          v.playsInline = true;
          v.preload = 'metadata';
          v.setAttribute('aria-label', n.media.alt);
          fig.appendChild(v);
        } else {
          const img = document.createElement('img');
          img.src = n.media.src;
          img.alt = n.media.alt;
          img.loading = 'lazy';
          fig.appendChild(img);
        }
      } else {
        const box = document.createElement('div');
        box.className = 'tl-media-pending';
        const tag = document.createElement('span');
        tag.className = 'hud-label';
        tag.textContent = `${n.media.type === 'video' ? 'Video' : 'Photo'} · to be added`;
        const desc = document.createElement('p');
        desc.textContent = n.media.alt;
        box.append(tag, desc);
        fig.appendChild(box);
      }
    }

    function openCard(n: TLNode) {
      populateCard(n);
      window.clearTimeout(hideTimer);
      card.hidden = false;
      dirty = true;
      requestAnimationFrame(() => {
        requestAnimationFrame(() => card.classList.add('open'));
      });
      card.querySelector<HTMLButtonElement>('#tl-card-close')?.focus({ preventScroll: true });
    }

    function closeCard(flyBack: boolean, refocus = false) {
      if (!activeId) return;
      const btn = btns.get(activeId);
      btn?.removeAttribute('data-active');
      btn?.setAttribute('aria-expanded', 'false');
      card.classList.remove('open');
      hideTimer = window.setTimeout(() => { card.hidden = true; }, 320);
      activeId = null;
      if (flyBack && prevCam) tweenTo(prevCam, 850);
      prevCam = null;
      if (refocus) btn?.focus({ preventScroll: true });
    }

    function flyToEvent(id: string) {
      const n = byId.get(id);
      if (!n) return;
      const swap = activeId !== null && activeId !== id;
      if (activeId && activeId !== id) {
        const old = btns.get(activeId);
        old?.removeAttribute('data-active');
        old?.setAttribute('aria-expanded', 'false');
      }
      if (!prevCam) prevCam = { x: cam.x, y: cam.y, k: cam.k };
      activeId = id;
      const btn = btns.get(id);
      btn?.setAttribute('data-active', '');
      btn?.setAttribute('aria-expanded', 'true');
      const k = flyK();
      // land the star where the card has room: left of center on desktop,
      // upper-center on phones (the card is a bottom sheet there)
      const fx = isSheet() ? 0.5 : 0.4;
      const fy = isSheet() ? 0.38 : 0.52;
      const target = {
        x: n.x + ((0.5 - fx) * W) / k,
        y: n.y + ((0.5 - fy) * H) / k,
        k,
      };
      if (swap && !card.hidden) {
        populateCard(n);
        tweenTo(target, 700);
      } else {
        tweenTo(target, 950, () => openCard(n));
      }
    }

    /* ---- rendering ---- */
    let edgeT0 = 0;
    let camPx = NaN;
    let camPy = NaN;
    let camPk = NaN;
    let readoutTxt = '';

    function draw(now: number) {
      ctx.clearRect(0, 0, W, H);
      const k = cam.k;

      // nebulae (depth 0.6)
      for (const b of nebulae) {
        const px = W / 2 + (b.x - cam.x) * k * 0.6;
        const py = H / 2 + (b.y - cam.y) * k * 0.6;
        const r = Math.max(90, b.r * k * 0.9);
        if (px + r < 0 || px - r > W || py + r < 0 || py - r > H) continue;
        const g = ctx.createRadialGradient(px, py, 0, px, py, r);
        g.addColorStop(0, `rgba(${b.c[0]},${b.c[1]},${b.c[2]},0.085)`);
        g.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = g;
        ctx.fillRect(px - r, py - r, r * 2, r * 2);
      }

      // starfield
      const t = now * 0.001;
      for (const layer of layers) {
        const kd = k * layer.d;
        for (const s of layer.stars) {
          const px = W / 2 + (s.x - cam.x) * kd;
          const py = H / 2 + (s.y - cam.y) * kd;
          if (px < -6 || px > W + 6 || py < -6 || py > H + 6) continue;
          const a = reduced ? s.a : s.a * (0.7 + 0.3 * Math.sin(t * s.sp + s.ph));
          const sz = Math.min(2.6, Math.max(0.5, s.s * (0.5 + k * 0.7)));
          ctx.globalAlpha = a;
          ctx.fillStyle = s.c;
          if (sz < 1.3) {
            ctx.fillRect(px, py, sz, sz);
          } else {
            ctx.beginPath();
            ctx.arc(px, py, sz / 2, 0, 6.2832);
            ctx.fill();
            if (s.glint) {
              ctx.strokeStyle = s.c;
              ctx.lineWidth = 0.6;
              ctx.globalAlpha = a * 0.55;
              const g = sz * 2.4;
              ctx.beginPath();
              ctx.moveTo(px - g, py);
              ctx.lineTo(px + g, py);
              ctx.moveTo(px, py - g);
              ctx.lineTo(px, py + g);
              ctx.stroke();
            }
          }
        }
      }
      ctx.globalAlpha = 1;

      // constellation edges (draw in with a stagger on first load)
      const alpha = Math.min(0.42, Math.max(0.16, 0.1 + k * 0.3));
      ctx.lineWidth = Math.min(1.6, Math.max(0.8, k * 1.1));
      data.edges.forEach((e, i) => {
        const p = reduced || !edgeT0 ? 1 : Math.min(1, Math.max(0, (now - edgeT0 - i * 110) / 650));
        if (p <= 0) return;
        const x1 = w2sX(e[0]);
        const y1 = w2sY(e[1]);
        const x2 = x1 + (w2sX(e[2]) - x1) * p;
        const y2 = y1 + (w2sY(e[3]) - y1) * p;
        if (e[4]) {
          ctx.setLineDash([5, 8]);
          ctx.strokeStyle = `rgba(148,178,255,${alpha * 0.45})`;
        } else {
          ctx.setLineDash([]);
          ctx.strokeStyle = `rgba(148,178,255,${alpha})`;
        }
        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);
        ctx.stroke();
      });
      ctx.setLineDash([]);
    }

    function updateDom() {
      for (const n of data.nodes) {
        const b = btns.get(n.id);
        if (!b) continue;
        b.style.transform = `translate3d(${w2sX(n.x).toFixed(1)}px, ${w2sY(n.y).toFixed(1)}px, 0)`;
      }
      yearEls.forEach((el, i) => {
        const y = data.years[i];
        el.style.transform =
          `translate3d(${w2sX(y.x).toFixed(1)}px, ${w2sY(y.y).toFixed(1)}px, 0) scale(${cam.k.toFixed(3)}) translate(-50%, -50%)`;
      });
      root.style.setProperty('--nk', Math.min(1.5, Math.max(0.75, 0.7 + cam.k * 0.45)).toFixed(3));
      const band = cam.k < homeK() * 1.5 ? 'far' : cam.k < flyK() * 0.8 ? 'mid' : 'near';
      if (root.dataset.band !== band) root.dataset.band = band;

      // anchor the card to its star (desktop; phones use the fixed sheet)
      if (activeId && !card.hidden && !isSheet()) {
        const n = byId.get(activeId)!;
        const sx = w2sX(n.x);
        const sy = w2sY(n.y);
        const cw = card.offsetWidth;
        const ch = card.offsetHeight || 300;
        let cardX = sx + 30;
        let originX = '-30px';
        if (cardX + cw > W - 16) {
          cardX = sx - 30 - cw;
          originX = `${cw + 30}px`;
        }
        const cardY = Math.min(Math.max(sy - ch * 0.45, 74), H - ch - 20);
        card.style.transform = `translate3d(${cardX.toFixed(1)}px, ${cardY.toFixed(1)}px, 0)`;
        cardInner.style.transformOrigin = `${originX} ${(sy - cardY).toFixed(1)}px`;
      }

      const txt =
        `Z ${cam.k.toFixed(2)} · X ${cam.x >= 0 ? '+' : ''}${Math.round(cam.x)}` +
        ` · Y ${cam.y >= 0 ? '+' : ''}${Math.round(cam.y)}`;
      if (txt !== readoutTxt) {
        readoutTxt = txt;
        readout.textContent = txt;
      }
    }

    /* ---- main loop ---- */
    let raf = 0;
    function loop(now: number) {
      if (!root.isConnected) return; // page was swapped out
      if (tween) {
        const p = Math.min(1, (now - tween.t0) / tween.dur);
        const e = easeOutQuart(p);
        cam.k = tween.fk * Math.pow(tween.tk / tween.fk, e);
        cam.x = tween.fx + (tween.tx - tween.fx) * e;
        cam.y = tween.fy + (tween.ty - tween.fy) * e;
        dirty = true;
        if (p >= 1) {
          const done = tween.done;
          tween = null;
          done?.();
        }
      }
      const introActive = edgeT0 && now - edgeT0 < data.edges.length * 110 + 800;
      if (!reduced || dirty || introActive) {
        const changed = cam.x !== camPx || cam.y !== camPy || cam.k !== camPk;
        draw(now);
        if (changed || dirty) {
          updateDom();
          camPx = cam.x;
          camPy = cam.y;
          camPk = cam.k;
        }
        dirty = false;
      }
      raf = requestAnimationFrame(loop);
    }

    /* ---- sizing ---- */
    function resize() {
      W = root.clientWidth;
      H = root.clientHeight;
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      canvas.width = Math.round(W * dpr);
      canvas.height = Math.round(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      clampCam();
      dirty = true;
    }
    const ro = new ResizeObserver(resize);
    ro.observe(root);
    resize();

    /* ---- input ---- */
    const ac = new AbortController();
    const sig = ac.signal;
    const rect = () => root.getBoundingClientRect();

    function zoomAt(mx: number, my: number, f: number) {
      const wx = cam.x + (mx - W / 2) / cam.k;
      const wy = cam.y + (my - H / 2) / cam.k;
      cam.k = Math.min(Math.max(cam.k * f, minK()), maxK());
      cam.x = wx - (mx - W / 2) / cam.k;
      cam.y = wy - (my - H / 2) / cam.k;
      clampCam();
      dirty = true;
    }

    const pointers = new Map<number, { x: number; y: number }>();
    let dragging = false;
    let moved = false;
    let px0 = 0, py0 = 0, camX0 = 0, camY0 = 0;
    let pinch: { d: number; k: number } | null = null;

    root.addEventListener(
      'pointerdown',
      (e) => {
        const t = e.target as HTMLElement;
        if (t.closest('.tl-star, #tl-card, .tl-ui')) return;
        pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
        root.setPointerCapture(e.pointerId);
        cancelTween();
        if (pointers.size === 1) {
          dragging = true;
          moved = false;
          px0 = e.clientX;
          py0 = e.clientY;
          camX0 = cam.x;
          camY0 = cam.y;
        } else if (pointers.size === 2) {
          dragging = false;
          const [a, b] = [...pointers.values()];
          pinch = { d: Math.hypot(a.x - b.x, a.y - b.y), k: cam.k };
        }
      },
      { signal: sig },
    );
    root.addEventListener(
      'pointermove',
      (e) => {
        if (!pointers.has(e.pointerId)) return;
        pointers.set(e.pointerId, { x: e.clientX, y: e.clientY });
        if (pinch && pointers.size === 2) {
          const [a, b] = [...pointers.values()];
          const d = Math.hypot(a.x - b.x, a.y - b.y) || 1;
          const r = rect();
          const mx = (a.x + b.x) / 2 - r.left;
          const my = (a.y + b.y) / 2 - r.top;
          zoomAt(mx, my, (pinch.k * (d / pinch.d)) / cam.k);
          moved = true;
        } else if (dragging) {
          const dx = e.clientX - px0;
          const dy = e.clientY - py0;
          if (Math.abs(dx) + Math.abs(dy) > 4) moved = true;
          cam.x = camX0 - dx / cam.k;
          cam.y = camY0 - dy / cam.k;
          clampCam();
          dirty = true;
        }
      },
      { signal: sig },
    );
    const endPointer = (e: PointerEvent) => {
      if (!pointers.has(e.pointerId)) return;
      pointers.delete(e.pointerId);
      if (pointers.size < 2) pinch = null;
      if (pointers.size === 1) {
        const [p] = [...pointers.values()];
        px0 = p.x;
        py0 = p.y;
        camX0 = cam.x;
        camY0 = cam.y;
        dragging = true;
      }
      if (pointers.size === 0) {
        if (dragging && !moved && activeId) closeCard(true);
        dragging = false;
      }
    };
    root.addEventListener('pointerup', endPointer, { signal: sig });
    root.addEventListener('pointercancel', endPointer, { signal: sig });

    root.addEventListener(
      'wheel',
      (e) => {
        e.preventDefault();
        const r = rect();
        cancelTween();
        zoomAt(e.clientX - r.left, e.clientY - r.top, Math.exp(-e.deltaY * (e.ctrlKey ? 0.0035 : 0.0014)));
      },
      { passive: false, signal: sig },
    );
    root.addEventListener(
      'dblclick',
      (e) => {
        if ((e.target as HTMLElement).closest('.tl-star, #tl-card, .tl-ui')) return;
        const r = rect();
        const mx = e.clientX - r.left;
        const my = e.clientY - r.top;
        const wx = cam.x + (mx - W / 2) / cam.k;
        const wy = cam.y + (my - H / 2) / cam.k;
        tweenTo({ x: wx, y: wy, k: Math.min(cam.k * 1.9, maxK()) }, 500);
      },
      { signal: sig },
    );

    root.addEventListener(
      'click',
      (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.tl-star');
        if (!btn) return;
        const id = btn.dataset.id!;
        if (activeId === id) closeCard(true, true);
        else flyToEvent(id);
      },
      { signal: sig },
    );
    document.getElementById('tl-card-close')!.addEventListener('click', () => closeCard(true, true), { signal: sig });
    document.getElementById('tl-zoom-in')!.addEventListener('click', () => zoomAt(W / 2, H / 2, 1.3), { signal: sig });
    document.getElementById('tl-zoom-out')!.addEventListener('click', () => zoomAt(W / 2, H / 2, 1 / 1.3), { signal: sig });
    document.getElementById('tl-reset')!.addEventListener(
      'click',
      () => {
        closeCard(false);
        tweenTo({ ...homeC(), k: homeK() }, 800);
      },
      { signal: sig },
    );

    document.addEventListener(
      'keydown',
      (e) => {
        if (!root.isConnected) return;
        if (e.key === 'Escape' && activeId) {
          closeCard(true, true);
          return;
        }
        // pan/zoom keys only when focus is on the map (or nothing in particular)
        const focusInMap = root.contains(document.activeElement) || document.activeElement === document.body;
        if (!focusInMap) return;
        const pan = 90 / cam.k;
        switch (e.key) {
          case '+':
          case '=': zoomAt(W / 2, H / 2, 1.25); break;
          case '-': zoomAt(W / 2, H / 2, 0.8); break;
          case '0': tweenTo({ ...homeC(), k: homeK() }, 800); break;
          case 'ArrowLeft': cam.x -= pan; clampCam(); dirty = true; break;
          case 'ArrowRight': cam.x += pan; clampCam(); dirty = true; break;
          case 'ArrowUp': cam.y -= pan; clampCam(); dirty = true; break;
          case 'ArrowDown': cam.y += pan; clampCam(); dirty = true; break;
          default: return;
        }
        e.preventDefault();
      },
      { signal: sig },
    );

    // tabbing to an off-screen star pans it into view
    root.addEventListener(
      'focusin',
      (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.tl-star');
        if (!btn) return;
        const n = byId.get(btn.dataset.id!);
        if (!n) return;
        const sx = w2sX(n.x);
        const sy = w2sY(n.y);
        const m = 70;
        if (sx < m || sx > W - m || sy < m || sy > H - m) {
          tweenTo({ x: n.x, y: n.y, k: cam.k }, 450);
        }
      },
      { signal: sig },
    );

    /* ---- lifecycle ---- */
    document.addEventListener(
      'astro:before-swap',
      () => {
        ac.abort();
        ro.disconnect();
        cancelAnimationFrame(raf);
        window.clearTimeout(hideTimer);
      },
      { once: true },
    );

    /* ---- intro: start pulled back, ease to home while the edges draw in ---- */
    const home = { ...homeC(), k: homeK() };
    if (reduced) {
      cam.x = home.x;
      cam.y = home.y;
      cam.k = home.k;
      clampCam();
    } else {
      cam.x = home.x;
      cam.y = home.y + 40;
      cam.k = home.k * 0.78;
      edgeT0 = performance.now() + 250;
      tweenTo(home, 1500);
    }
    root.dataset.ready = '1';
    raf = requestAnimationFrame(loop);
  }

  initConstellation();
  document.addEventListener('astro:page-load', initConstellation);
</script>
