---
/**
 * SubsystemLanes - three color-coded lanes summarizing the domains I work
 * across on the team. Each links to the filtered post grid below.
 */
import { subsystems, subsystemOrder } from '../../config/fsae';
import Stagger from '../motion/Stagger.astro';
import CornerBrackets from '../hud/CornerBrackets.astro';

interface Props {
  counts: Record<string, number>;
}
const { counts } = Astro.props;
---

<Stagger class="grid grid-cols-1 gap-4 md:grid-cols-3" gap={90}>
  {
    subsystemOrder.map((id, i) => {
      const m = subsystems[id];
      return (
        <a
          href="#log"
          data-jump-filter={id}
          data-stagger-item
          class="group relative flex flex-col overflow-hidden border border-line bg-surface p-6 transition-colors duration-300"
          style={`--sc:${m.color}`}
        >
          <CornerBrackets size={14} inset={8} color="var(--sc)" />
          <div class="flex items-center justify-between">
            <span class="font-mono text-xs" style={`color:${m.color}`}>
              {String(i + 1).padStart(2, '0')} · {m.code}
            </span>
            <span
              class="h-2.5 w-2.5 rounded-full"
              style={`background:${m.color};box-shadow:0 0 12px ${m.color}`}
            />
          </div>
          <h3 class="mt-8 font-display text-2xl text-ink">{m.label}</h3>
          <p class="mt-3 grow text-sm leading-relaxed text-muted">{m.blurb}</p>
          <div class="mt-5 flex flex-wrap gap-1.5">
            {m.focus.map((f) => (
              <span class="font-mono text-[0.6rem] uppercase tracking-wider text-faint">{f}</span>
            ))}
          </div>
          <div class="mt-6 flex items-center justify-between border-t border-line-soft pt-4">
            <span class="hud-label">
              {counts[id] ?? 0} {(counts[id] ?? 0) === 1 ? 'entry' : 'entries'}
            </span>
            <span class="hud-label transition-colors group-hover:text-ink">READ →</span>
          </div>
        </a>
      );
    })
  }
</Stagger>

<style>
  a[style*='--sc'] {
    transition: border-color 0.3s var(--ease-out-hud);
  }
  a[style*='--sc']:hover {
    border-color: color-mix(in srgb, var(--sc) 55%, transparent);
  }
</style>
