---
/**
 * SlamTrack - isometric pose-graph map of a driverless track, rendered like
 * the live output of the SLAM stack: rule-colored cone landmarks (FSG spec:
 * blue on the driver's left, yellow on the right, big orange at the timing
 * line), a checkered start/finish strip, a dashed estimated trajectory, pose
 * nodes, and a formula car lapping the circuit with a scan pulse.
 *
 * All geometry is computed at build time; the only client JS drives the car
 * along the projected path with anime.js (skipped under reduced motion).
 */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

/**
 * Real-run support (council plan Phase 4): drop an export of an actual logged
 * session at `src/data/slam-run.json` and every SlamTrack instance renders it
 * instead of the synthetic circuit. Expected shape (world coords, any units):
 *   { "centerline": [[x, y], ...],                 // closed-loop driven path
 *     "cones": { "left": [[x, y], ...], "right": [[x, y], ...] } }  // optional
 * When `cones` is omitted they are generated by offsetting the centerline.
 */
interface RunData {
  centerline: [number, number][];
  cones?: { left: [number, number][]; right: [number, number][] };
}
const runModules = import.meta.glob<{ default: RunData }>('../../data/slam-run.json', {
  eager: true,
});
const rawRun: RunData | undefined = Object.values(runModules)[0]?.default;

/* Normalize real data (meters, arbitrary origin, even UTM) into the same
   ~100-unit world box the synthetic circuit uses, so every size constant
   (cone radius, car, grid, checker strip) keeps working unchanged. */
function normalizeRun(r: RunData): RunData {
  const all = [...r.centerline, ...(r.cones ? [...r.cones.left, ...r.cones.right] : [])];
  const minX = Math.min(...all.map((p) => p[0]));
  const minY = Math.min(...all.map((p) => p[1]));
  const extent = Math.max(
    Math.max(...all.map((p) => p[0])) - minX,
    Math.max(...all.map((p) => p[1])) - minY,
  ) || 1;
  const norm = ([x, y]: [number, number]): [number, number] => [
    ((x - minX) / extent) * 100,
    ((y - minY) / extent) * 100,
  ];
  return {
    centerline: r.centerline.map(norm),
    cones: r.cones
      ? { left: r.cones.left.map(norm), right: r.cones.right.map(norm) }
      : undefined,
  };
}
const run = rawRun ? normalizeRun(rawRun) : undefined;

/* ---- world-space centerline (real run, else synthetic S-section circuit) ---- */
const ctrl: [number, number][] = run?.centerline ?? [
  [12, 30], [20, 10], [45, 5], [70, 8], [88, 18], [90, 38],
  [78, 50], [62, 46], [50, 34], [38, 36], [34, 52], [22, 58],
];

/* isometric projection (linear, so it commutes with the spline math) */
const ISO_X = Math.cos(Math.PI / 6);
const ISO_Y = Math.sin(Math.PI / 6);
const iso = ([x, y]: [number, number]): [number, number] => [
  (x - y) * ISO_X,
  (x + y) * ISO_Y,
];

/* closed Catmull-Rom -> cubic bezier segments, sampled for cones/normals */
const n = ctrl.length;
const at = (i: number) => ctrl[((i % n) + n) % n];
type Seg = { p1: [number, number]; c1: [number, number]; c2: [number, number]; p2: [number, number] };
const segs: Seg[] = ctrl.map((_, i) => {
  const p0 = at(i - 1), p1 = at(i), p2 = at(i + 1), p3 = at(i + 2);
  return {
    p1,
    c1: [p1[0] + (p2[0] - p0[0]) / 6, p1[1] + (p2[1] - p0[1]) / 6],
    c2: [p2[0] - (p3[0] - p1[0]) / 6, p2[1] - (p3[1] - p1[1]) / 6],
    p2,
  };
});

function bezier(s: Seg, t: number): [number, number] {
  const u = 1 - t;
  const w = [u * u * u, 3 * u * u * t, 3 * u * t * t, t * t * t];
  return [
    w[0] * s.p1[0] + w[1] * s.c1[0] + w[2] * s.c2[0] + w[3] * s.p2[0],
    w[0] * s.p1[1] + w[1] * s.c1[1] + w[2] * s.c2[1] + w[3] * s.p2[1],
  ];
}

const STEPS = 10;
const samples: [number, number][] = segs.flatMap((s) =>
  Array.from({ length: STEPS }, (_, k) => bezier(s, k / STEPS)),
);
const m = samples.length;

/* cone landmarks: offset from the centerline along world-space normals.
   The normal (-dy, dx) points to the DRIVER'S RIGHT in screen coords (y-down),
   so per the FS ruleset: side +1 = yellow, side -1 = blue. */
const HALF_W = 4.2;
const CONE_EVERY = 3;
const CONE_YELLOW = '#eab308';
const CONE_BLUE = '#2563eb';
const CONE_ORANGE = '#f97316';

interface Cone { x: number; y: number; color: string }
const cones: Cone[] = [];
if (run?.cones) {
  for (const c of run.cones.right) {
    const [px, py] = iso(c);
    cones.push({ x: px, y: py, color: CONE_YELLOW });
  }
  for (const c of run.cones.left) {
    const [px, py] = iso(c);
    cones.push({ x: px, y: py, color: CONE_BLUE });
  }
} else {
  for (let i = CONE_EVERY; i < m; i += CONE_EVERY) {
    const prev = samples[(i - 1 + m) % m];
    const next = samples[(i + 1) % m];
    const [dx, dy] = [next[0] - prev[0], next[1] - prev[1]];
    const len = Math.hypot(dx, dy) || 1;
    const nx = -dy / len, ny = dx / len;
    const p = samples[i];
    for (const side of [1, -1]) {
      const [px, py] = iso([p[0] + nx * HALF_W * side, p[1] + ny * HALF_W * side]);
      cones.push({ x: px, y: py, color: side === 1 ? CONE_YELLOW : CONE_BLUE });
    }
  }
}

/* start/finish: checkered strip across the track + big orange timing cones */
const sP = samples[0];
const sN = samples[1];
const [sdx, sdy] = [sN[0] - sP[0], sN[1] - sP[1]];
const sLen = Math.hypot(sdx, sdy) || 1;
const st: [number, number] = [sdx / sLen, sdy / sLen]; // tangent (direction of travel)
const sn: [number, number] = [-st[1], st[0]]; // driver's right

const CHECK_COLS = 8;
const CHECK_ROWS = 2;
const checkW = (HALF_W * 2) / CHECK_COLS;
const checkT = 0.85;
interface Check { points: string; dark: boolean }
const checkers: Check[] = [];
for (let r = 0; r < CHECK_ROWS; r++) {
  for (let c = 0; c < CHECK_COLS; c++) {
    const corner = (du: number, dv: number): [number, number] =>
      iso([
        sP[0] + sn[0] * (-HALF_W + (c + du) * checkW) + st[0] * (r + dv - CHECK_ROWS / 2) * checkT,
        sP[1] + sn[1] * (-HALF_W + (c + du) * checkW) + st[1] * (r + dv - CHECK_ROWS / 2) * checkT,
      ]);
    const pts = [corner(0, 0), corner(1, 0), corner(1, 1), corner(0, 1)]
      .map(([x, y]) => `${x.toFixed(2)},${y.toFixed(2)}`)
      .join(' ');
    checkers.push({ points: pts, dark: (r + c) % 2 === 0 });
  }
}

const gateCones = [1, -1].map((side) =>
  iso([sP[0] + sn[0] * (HALF_W + 0.9) * side, sP[1] + sn[1] * (HALF_W + 0.9) * side]),
);

/* pose-graph nodes along the trajectory */
const poses = samples.filter((_, i) => i % 8 === 0).map(iso);

/* projected trajectory path */
const P = (pt: [number, number]) => `${pt[0].toFixed(2)} ${pt[1].toFixed(2)}`;
const pathD =
  `M ${P(iso(segs[0].p1))} ` +
  segs.map((s) => `C ${P(iso(s.c1))}, ${P(iso(s.c2))}, ${P(iso(s.p2))}`).join(' ') +
  ' Z';

/* faint iso floor grid */
const gridLines: string[] = [];
for (let g = -10; g <= 110; g += 20) {
  gridLines.push(`M ${P(iso([g, -15]))} L ${P(iso([g, 80]))}`);
  if (g <= 80) gridLines.push(`M ${P(iso([-10, g - 10]))} L ${P(iso([105, g - 10]))}`);
}

/* viewBox from projected extents */
const allPts = [...samples.map(iso), ...cones.map((c) => [c.x, c.y] as [number, number])];
const xs = allPts.map((p) => p[0]), ys = allPts.map((p) => p[1]);
const PAD = 10;
const minX = Math.min(...xs) - PAD, minY = Math.min(...ys) - PAD;
const vbW = Math.max(...xs) - minX + PAD, vbH = Math.max(...ys) - minY + PAD;

const start = iso(samples[0]);
const startAngle =
  (Math.atan2(iso(samples[1])[1] - start[1], iso(samples[1])[0] - start[0]) * 180) / Math.PI;
---

<svg
  data-slam-track
  viewBox={`${minX.toFixed(1)} ${minY.toFixed(1)} ${vbW.toFixed(1)} ${vbH.toFixed(1)}`}
  preserveAspectRatio="xMidYMid slice"
  class={className}
  fill="none"
  aria-hidden="true"
>
  <!-- iso floor grid -->
  <g stroke="var(--color-line-soft)" stroke-width="0.15" opacity="0.6">
    {gridLines.map((d) => <path d={d} />)}
  </g>

  <!-- estimated trajectory (dashed, SLAM-style) -->
  <path
    data-slam-path
    d={pathD}
    stroke="var(--color-faint)"
    stroke-width="0.4"
    stroke-dasharray="1.6 1.6"
    opacity="0.8"
  />

  <!-- pose-graph nodes -->
  <g fill="var(--color-muted)" opacity="0.5">
    {poses.map(([x, y]) => <rect x={x - 0.5} y={y - 0.5} width="1" height="1" />)}
  </g>

  <!-- checkered start/finish strip -->
  <g opacity="0.85">
    {checkers.map((k) => <polygon points={k.points} fill={k.dark ? '#101012' : '#d4d4d8'} />)}
  </g>

  <!-- cone landmarks: yellow driver-right, blue driver-left (FS rules) -->
  <g data-slam-cones>
    {cones.map((c) => <circle cx={c.x} cy={c.y} r="0.9" fill={c.color} opacity="0.85" />)}
  </g>

  <!-- big orange timing cones flanking the start line -->
  {gateCones.map(([x, y]) => <circle cx={x} cy={y} r="1.35" fill={CONE_ORANGE} opacity="0.95" />)}

  <!-- the car (top-view formula outline, dark blue) + scan pulse -->
  <g data-slam-car transform={`translate(${P(start).replace(' ', ', ')}) rotate(${startAngle.toFixed(1)})`}>
    <circle class="slam-scan" r="6" stroke="var(--color-cyan)" stroke-width="0.3" />
    <g fill="#1e3a8a" stroke="#3b82f6" stroke-width="0.22">
      <!-- wheels -->
      <rect x="1.15" y="-2.05" width="1.15" height="0.7" rx="0.25" />
      <rect x="1.15" y="1.35" width="1.15" height="0.7" rx="0.25" />
      <rect x="-2.75" y="-2.2" width="1.35" height="0.8" rx="0.25" />
      <rect x="-2.75" y="1.4" width="1.35" height="0.8" rx="0.25" />
      <!-- front wing -->
      <rect x="2.85" y="-1.95" width="0.6" height="3.9" rx="0.15" />
      <!-- rear wing -->
      <rect x="-3.45" y="-1.75" width="0.7" height="3.5" rx="0.15" />
      <!-- monocoque: nose to engine cover -->
      <path d="M3.3 0 L1.7 -0.7 L0.3 -0.95 L-1.1 -0.65 L-2.5 -0.75 L-2.5 0.75 L-1.1 0.65 L0.3 0.95 L1.7 0.7 Z" />
    </g>
    <!-- cockpit opening -->
    <ellipse cx="-0.35" cy="0" rx="0.6" ry="0.42" fill="#09090b" opacity="0.85" />
  </g>
</svg>

<style>
  .slam-scan {
    transform-origin: center;
    transform-box: fill-box;
    animation: slam-scan 2.4s var(--ease-out-hud, ease-out) infinite;
  }
  @keyframes slam-scan {
    0% { transform: scale(0.2); opacity: 0.8; }
    100% { transform: scale(1); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .slam-scan { animation: none; opacity: 0.25; }
  }
</style>

<script>
  import { animate, createMotionPath } from 'animejs';

  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function initSlamTracks() {
    document.querySelectorAll<SVGSVGElement>('[data-slam-track]').forEach((svgEl) => {
      if (svgEl.dataset.bound) return;
      svgEl.dataset.bound = '1';
      const path = svgEl.querySelector<SVGPathElement>('[data-slam-path]');
      const car = svgEl.querySelector<SVGGElement>('[data-slam-car]');
      if (!path || !car || reduced) return;

      // The static transform is only the no-JS / reduced-motion resting pose.
      car.removeAttribute('transform');
      const motionPath = createMotionPath(path);
      if (!motionPath) return;
      animate(car, {
        ...motionPath,
        duration: 26000,
        ease: 'linear',
        loop: true,
      });
    });
  }
  initSlamTracks();
  document.addEventListener('astro:page-load', initSlamTracks);
</script>
