---
/**
 * PostCard - an FSAE build-log entry preview. Uses the post cover if present,
 * otherwise an on-brand placeholder.
 */
import { Image } from 'astro:assets';
import { subsystems, type Subsystem } from '../../config/fsae';
import SubsystemBadge from './SubsystemBadge.astro';
import Placeholder from '../media/Placeholder.astro';
import CornerBrackets from '../hud/CornerBrackets.astro';

interface Props {
  href: string;
  title: string;
  summary: string;
  subsystem: Subsystem;
  date: Date;
  season?: string;
  cover?: ImageMetadata;
}
const { href, title, summary, subsystem, date, season, cover } = Astro.props;
const meta = subsystems[subsystem];
const dateStr = date.toISOString().slice(0, 10);
---

<a
  href={href}
  data-stagger-item
  data-subsystem={subsystem}
  class="group relative flex flex-col overflow-hidden border border-line bg-surface transition-colors duration-300 hover:border-cyan/50"
>
  <div class="relative overflow-hidden">
    {
      cover ? (
        <Image
          src={cover}
          alt={title}
          widths={[400, 800]}
          sizes="(min-width: 768px) 33vw, 100vw"
          class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
        />
      ) : (
        <Placeholder ratio="16/10" label={`${meta.code} · ${dateStr}`} seed={subsystem.length} />
      )
    }
    <span class="absolute left-3 top-3"><SubsystemBadge subsystem={subsystem} /></span>
  </div>
  <div class="flex grow flex-col p-5">
    <div class="mb-3 flex items-center gap-3">
      <span class="hud-label tabular">{dateStr}</span>
      {season && <span class="hud-label">· {season}</span>}
    </div>
    <h3 class="font-display text-xl text-ink transition-colors group-hover:text-cyan">{title}</h3>
    <p class="mt-2 grow text-sm text-muted">{summary}</p>
    <span class="hud-label mt-5 transition-colors group-hover:text-ink">READ ENTRY →</span>
  </div>
  <CornerBrackets size={12} inset={6} color="var(--color-line)" />
</a>
