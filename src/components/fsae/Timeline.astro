---
/**
 * Timeline — vertical season/milestone rail with a scroll-drawn spine.
 */
interface TimelineItem {
  marker: string;
  title: string;
  detail: string;
  tag?: string;
}
interface Props {
  items: TimelineItem[];
}
const { items } = Astro.props;
---

<div class="relative pl-8">
  <!-- animated spine -->
  <svg
    class="pointer-events-none absolute left-[3px] top-1 h-full w-2 text-accent"
    viewBox="0 0 2 100"
    preserveAspectRatio="none"
    fill="none"
    data-draw="scroll"
    aria-hidden="true"
  >
    <line x1="1" y1="0" x2="1" y2="100" stroke="currentColor" stroke-width="2" />
  </svg>

  <ol class="space-y-10">
    {
      items.map((item) => (
        <li class="relative" data-reveal="left">
          <span
            class="absolute -left-8 top-1.5 h-2.5 w-2.5 -translate-x-[3px] rounded-full border border-accent bg-bg"
            aria-hidden="true"
          />
          <div class="flex flex-wrap items-baseline gap-3">
            <span class="hud-label tabular text-accent">{item.marker}</span>
            <h3 class="font-display text-xl text-ink">{item.title}</h3>
            {item.tag && <span class="hud-label">· {item.tag}</span>}
          </div>
          <p class="mt-2 max-w-2xl text-sm leading-relaxed text-muted">{item.detail}</p>
        </li>
      ))
    }
  </ol>
</div>
