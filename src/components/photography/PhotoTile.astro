---
/**
 * PhotoTile — one masonry gallery cell. A button that opens the lightbox
 * (wired by index). Shows an EXIF micrographic overlay on hover/focus.
 */
import { Image } from 'astro:assets';
import Placeholder from '../media/Placeholder.astro';

interface Props {
  index: number;
  title: string;
  settings?: string;
  location?: string;
  ratio: string;
  image?: ImageMetadata;
}
const { index, title, settings, location, ratio, image } = Astro.props;
const idx = String(index + 1).padStart(3, '0');
---

<button
  type="button"
  data-photo-index={index}
  data-stagger-item
  class="group relative mb-4 block w-full break-inside-avoid overflow-hidden border border-line bg-surface text-left transition-colors duration-300 hover:border-cyan/60 focus-visible:border-cyan"
  aria-label={`Open photo: ${title}`}
>
  {
    image ? (
      <Image
        src={image}
        alt={title}
        widths={[400, 800]}
        sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
        class="w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
      />
    ) : (
      <Placeholder ratio={ratio} label={`IMG_${idx}`} seed={index} class="border-0" />
    )
  }

  <!-- top-right expand reticle -->
  <span class="pointer-events-none absolute right-2 top-2 opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="text-cyan" aria-hidden="true">
      <path d="M2 6V2h4M14 6V2h-4M2 10v4h4M14 10v4h-4" stroke="currentColor" stroke-width="1.2" />
    </svg>
  </span>

  <!-- EXIF overlay -->
  <span
    class="pointer-events-none absolute inset-x-0 bottom-0 translate-y-1 bg-gradient-to-t from-bg/95 via-bg/60 to-transparent p-3 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:translate-y-0 group-focus-visible:opacity-100"
  >
    <span class="block font-display text-sm text-ink">{title}</span>
    {settings && <span class="mt-0.5 block font-mono text-[0.6rem] tracking-wider text-cyan">{settings}</span>}
    {location && <span class="mt-0.5 block font-mono text-[0.6rem] tracking-wider text-faint">{location}</span>}
  </span>
</button>
