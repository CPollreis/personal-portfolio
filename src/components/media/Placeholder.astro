---
/**
 * Placeholder — intentional HUD "asset pending" frame used until real photos /
 * screenshots are dropped in. Reads as a targeting viewport, not a broken image.
 * Swap for astro:assets <Image> once assets exist.
 */
import CornerBrackets from '../hud/CornerBrackets.astro';

interface Props {
  /** CSS aspect-ratio, e.g. "16/9", "4/3", "1/1", "3/4". */
  ratio?: string;
  /** Small mono caption, e.g. "IMG_0421 · 24MM". */
  label?: string;
  /** Seed to vary the gradient hue slightly per instance. */
  seed?: number;
  class?: string;
}

const { ratio = '16/9', label = 'ASSET PENDING', seed = 0, class: className = '' } = Astro.props;

// Slightly vary the accent wash so a grid of placeholders isn't monotonous.
const hue = [
  'from-accent/15',
  'from-cyan/15',
  'from-indigo/15',
][seed % 3];
---

<div
  class={`group relative overflow-hidden border border-line bg-surface ${className}`}
  style={`aspect-ratio:${ratio}`}
>
  <div class={`absolute inset-0 bg-gradient-to-br ${hue} to-transparent`} aria-hidden="true"></div>
  <!-- fine grid wash -->
  <div
    class="absolute inset-0 opacity-40"
    style="background-image:linear-gradient(var(--color-line-soft) 1px,transparent 1px),linear-gradient(90deg,var(--color-line-soft) 1px,transparent 1px);background-size:28px 28px"
    aria-hidden="true"
  >
  </div>
  <!-- center reticle mark -->
  <svg
    class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-faint transition-colors duration-300 group-hover:text-cyan"
    width="40"
    height="40"
    viewBox="0 0 40 40"
    fill="none"
    aria-hidden="true"
  >
    <path d="M20 6v9M20 25v9M6 20h9M25 20h9" stroke="currentColor" stroke-width="1" />
    <circle cx="20" cy="20" r="7" stroke="currentColor" stroke-width="1" opacity="0.6" />
  </svg>
  <CornerBrackets size={12} inset={8} color="var(--color-faint)" />
  <span class="hud-label absolute bottom-3 left-3">{label}</span>
</div>
