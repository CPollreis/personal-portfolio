---
/**
 * SkillMatrix — categorized skill panels in the HUD language. Data-driven so
 * it's easy to keep current.
 */
import Stagger from '../motion/Stagger.astro';
import CornerBrackets from '../hud/CornerBrackets.astro';

interface Group {
  code: string;
  label: string;
  color: string;
  skills: string[];
}

const groups: Group[] = [
  {
    code: 'FW',
    label: 'Embedded & Firmware',
    color: 'var(--color-accent)',
    skills: ['C / C++', 'Embedded C', 'RTOS', 'CAN bus', 'ARM Cortex-M', 'KiCad'],
  },
  {
    code: 'AV',
    label: 'Autonomy & ML',
    color: 'var(--color-indigo)',
    skills: ['Python', 'ROS 2', 'PyTorch', 'SLAM', 'Computer Vision', 'Reinforcement Learning'],
  },
  {
    code: 'SW',
    label: 'Software & Tools',
    color: 'var(--color-cyan)',
    skills: ['Git', 'Linux', 'Docker', 'TypeScript', 'SQLite', 'Astro / React'],
  },
  {
    code: 'MFG',
    label: 'Manufacturing',
    color: 'var(--color-muted)',
    skills: ['Composites', 'CNC', 'SolidWorks', 'DFM', 'Soldering / Rework'],
  },
];
---

<Stagger class="grid grid-cols-1 gap-4 sm:grid-cols-2" gap={70}>
  {
    groups.map((g) => (
      <div data-stagger-item class="relative border border-line bg-surface p-6">
        <CornerBrackets size={12} inset={8} color="var(--color-line)" />
        <div class="mb-5 flex items-center gap-3">
          <span class="font-mono text-xs" style={`color:${g.color}`}>{g.code}</span>
          <span class="h-2 w-2" style={`background:${g.color}`} />
          <h3 class="font-display text-lg text-ink">{g.label}</h3>
        </div>
        <ul class="flex flex-wrap gap-2">
          {g.skills.map((s) => (
            <li class="border border-line-soft px-2.5 py-1 font-mono text-[0.68rem] uppercase tracking-wider text-muted">
              {s}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</Stagger>
