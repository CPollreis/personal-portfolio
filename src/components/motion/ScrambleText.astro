---
/**
 * ScrambleText - decode/scramble reveal of its text when scrolled into view.
 * Keep contents to a single line of plain text for best effect.
 */
interface Props {
  as?: keyof HTMLElementTagNameMap;
  text: string;
  class?: string;
}

const { as = 'span', text, class: className = '' } = Astro.props as Props;
const Tag = as;
---

<Tag class={className} data-scramble>{text}</Tag>
