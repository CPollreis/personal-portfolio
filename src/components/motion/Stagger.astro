---
/**
 * Stagger — cascade direct children (or [data-stagger-item] descendants) into
 * view. Wrap a grid/list; each child animates in sequence.
 */
interface Props {
  as?: keyof HTMLElementTagNameMap;
  gap?: number;
  class?: string;
}

const { as = 'div', gap, class: className = '' } = Astro.props as Props;
const Tag = as;
---

<Tag class={className} data-stagger data-stagger-gap={gap}>
  <slot />
</Tag>
