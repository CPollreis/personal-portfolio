---
/**
 * Footer - contact, socials, and a final micrographic flourish (telemetry
 * readout strip). Keeps the HUD language consistent to the last pixel.
 */
import { site, socials } from '../../config/site';
import { withBase } from '../../config/paths';
import SocialIcon from '../ui/SocialIcon.astro';

const year = new Date().getFullYear();
---

<footer class="relative border-t border-line bg-surface/40">
  <div class="container-hud py-10">
    <!-- Telemetry readout strip -->
    <div class="mb-8 flex flex-wrap items-center gap-x-8 gap-y-3">
      <span class="hud-label text-accent">SYS.STATUS</span>
      <span class="hud-label">ONLINE</span>
      <span class="h-px flex-1 bg-line" aria-hidden="true"></span>
      <span class="hud-label tabular">LAT 49.90°</span>
      <span class="hud-label tabular">LON -97.14°</span>
      <span class="hud-label tabular">WPG <span id="hud-clock">--:--:--</span></span>
      <span class="hud-label tabular">v{year}.1</span>
    </div>

    <div class="flex flex-col gap-8 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-display text-2xl text-ink">{site.name}</p>
        <p class="mt-2 max-w-sm text-sm text-muted">{site.tagline}</p>
      </div>

      <div class="flex flex-col gap-5 sm:items-end">
        <div>
          <p class="hud-label mb-4">Connect</p>
          <ul class="flex items-center gap-4">
            {
              socials.map((s) => (
                <li>
                  <a
                    href={s.href}
                    class="link-hud inline-flex text-muted hover:text-ink"
                    aria-label={s.label}
                    rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                    target={s.href.startsWith('http') ? '_blank' : undefined}
                  >
                    <SocialIcon label={s.label} />
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <a
          href={withBase(site.resume)}
          target="_blank"
          rel="noopener noreferrer"
          class="hud-label inline-flex items-center gap-1.5 border border-line px-3 py-1.5 text-muted transition-colors hover:border-faint hover:text-ink"
        >
          Resume <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>

    <div class="mt-10 flex flex-col gap-2 border-t border-line-soft pt-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="hud-label">© {year} {site.name} · All systems nominal</p>
      <a href={withBase('/colophon')} class="link-hud hud-label hover:text-ink">Built with Astro · anime.js → Colophon</a>
    </div>
  </div>
</footer>
