---
/**
 * Nav - persistent top bar. Wordmark plus the photography tab; everything
 * else lives on the one-page home. Mobile keeps the accessible drawer.
 */
import { nav, site } from '../../config/site';
import { withBase } from '../../config/paths';

// Breadcrumb trail from the current path, shown next to the wordmark like a file
// directory so a visitor always sees where they are and can click back up. The
// home page shows no trail (the wordmark alone is enough).
const rel = Astro.url.pathname.slice(withBase('/').length).replace(/\/+$/, '');
const segments = rel ? rel.split('/') : [];
// First-level sections live on the one-page home, so their crumb points at the
// on-page anchor; the last segment is the current page and is not a link.
const crumbHref = (i: number): string | undefined => {
  if (i === segments.length - 1) return undefined;
  const seg = segments[i];
  if (seg === 'fsae') return '/#fsae';
  if (seg === 'projects') return '/#projects';
  return '/' + segments.slice(0, i + 1).join('/');
};
---

<header class="fixed inset-x-0 top-0 z-40 border-b border-line bg-bg/80 backdrop-blur-md">
  <nav class="container-hud flex h-16 items-center justify-between" aria-label="Primary">
    <div class="flex min-w-0 items-center gap-2.5">
      <a href={withBase('/')} class="group flex items-center gap-2.5" aria-label={`${site.name}, home`}>
        <span
          class="grid h-7 w-7 place-items-center border border-line text-accent transition-colors group-hover:border-accent"
          aria-hidden="true"
        >
          <span class="font-mono text-xs font-bold">C</span>
        </span>
        <span class="hidden font-mono text-sm tracking-wide text-ink sm:block">
          {site.name.replace(/\s+/g, '').toLowerCase()}<span class="text-faint">.com</span>
        </span>
      </a>

      {
        segments.length > 0 && (
          <nav
            aria-label="Breadcrumb"
            class="flex min-w-0 items-center gap-1.5 font-mono text-xs tracking-wide"
          >
            {segments.map((seg, i) => {
              const href = crumbHref(i);
              return (
                <span class="flex min-w-0 items-center gap-1.5">
                  <span class="text-faint" aria-hidden="true">
                    /
                  </span>
                  {href ? (
                    <a
                      href={withBase(href)}
                      class="text-muted transition-colors hover:text-ink"
                    >
                      {seg}
                    </a>
                  ) : (
                    <span class="min-w-0 max-w-[50vw] truncate text-ink" aria-current="page">
                      {seg}
                    </span>
                  )}
                </span>
              );
            })}
          </nav>
        )
      }
    </div>

    {
      nav.length > 0 && (
        <>
          {/* Desktop nav */}
          <ul class="hidden items-center gap-1 md:flex">
            {nav.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  class="flex items-center gap-2 px-3 py-2 font-mono text-xs uppercase tracking-widest text-muted transition-colors hover:text-ink"
                >
                  <span class="text-faint">{item.index}</span>
                  <span>{item.label}</span>
                </a>
              </li>
            ))}
          </ul>

          {/* Mobile toggle */}
          <button
            type="button"
            id="nav-toggle"
            class="grid h-10 w-10 place-items-center border border-line text-ink md:hidden"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-drawer"
          >
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M2 5h14M2 13h14" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </button>
        </>
      )
    }
  </nav>

  <!-- Mobile drawer -->
  {
    nav.length > 0 && (
      <div
        id="mobile-drawer"
        class="fixed inset-0 z-40 hidden translate-y-0 flex-col bg-bg/98 backdrop-blur-lg md:hidden"
        role="dialog"
        aria-modal="true"
        aria-label="Menu"
      >
        <div class="container-hud flex h-16 items-center justify-between border-b border-line">
          <span class="hud-label">Navigation</span>
          <button
            type="button"
            id="nav-close"
            class="grid h-10 w-10 place-items-center border border-line text-ink"
            aria-label="Close menu"
          >
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4 4l10 10M14 4L4 14" stroke="currentColor" stroke-width="1.5" />
            </svg>
          </button>
        </div>
        <ul class="container-hud flex flex-col gap-1 py-8">
          {nav.map((item) => (
            <li>
              <a
                href={withBase(item.href)}
                class="flex items-baseline gap-4 border-b border-line-soft py-5 font-display text-2xl text-muted"
              >
                <span class="font-mono text-xs text-accent">{item.index}</span>
                <span>{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</header>

<script>
  // Delegated so the bindings survive ClientRouter page swaps (the header is
  // re-rendered per page; document-level listeners are registered once).
  function setOpen(open: boolean, refocus = true) {
    const drawer = document.getElementById('mobile-drawer');
    const toggle = document.getElementById('nav-toggle');
    if (!drawer || !toggle) return;
    drawer.classList.toggle('hidden', !open);
    drawer.classList.toggle('flex', open);
    toggle.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
    if (!refocus) return;
    if (open) {
      (drawer.querySelector('a') as HTMLElement | null)?.focus();
    } else {
      toggle.focus();
    }
  }

  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement | null;
    if (!t) return;
    if (t.closest('#nav-toggle')) setOpen(true);
    else if (t.closest('#nav-close')) setOpen(false);
    else if (t.closest('#mobile-drawer a')) setOpen(false, false);
  });
  document.addEventListener('keydown', (e) => {
    const drawer = document.getElementById('mobile-drawer');
    if (e.key === 'Escape' && drawer && !drawer.classList.contains('hidden')) setOpen(false);
  });
  // A page swap replaces the drawer in its closed state; clear the scroll lock.
  document.addEventListener('astro:after-swap', () => {
    document.body.style.overflow = '';
  });
</script>
