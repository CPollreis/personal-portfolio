---
/**
 * DataReadout - a telemetry stat block: label, animated value, and unit.
 * Uses the motion engine's counter. Great for stat rows / bento cells.
 */
import Counter from '../motion/Counter.astro';

interface Props {
  label: string;
  value: number;
  suffix?: string;
  unit?: string;
  class?: string;
}

const { label, value, suffix = '', unit, class: className = '' } = Astro.props;
---

<div class={`flex flex-col gap-2 ${className}`}>
  <span class="hud-label">{label}</span>
  <div class="flex items-baseline gap-1.5">
    <span class="font-display text-4xl font-semibold text-ink md:text-5xl">
      <Counter value={value} suffix={suffix} />
    </span>
    {unit && <span class="font-mono text-sm text-faint">{unit}</span>}
  </div>
</div>
