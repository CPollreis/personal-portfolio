---
/**
 * CircuitTrace — decorative PCB-style trace that line-draws on scroll (via the
 * motion engine's data-draw="scroll"). Purely aesthetic (aria-hidden).
 */
interface Props {
  class?: string;
  color?: string;
  /** "scroll" draws synced to scroll; "enter" draws once on view. */
  mode?: 'scroll' | 'enter';
}

const { class: className = '', color = 'var(--color-accent)', mode = 'scroll' } = Astro.props;
---

<svg
  viewBox="0 0 400 120"
  fill="none"
  preserveAspectRatio="xMidYMid meet"
  class={className}
  style={`--c:${color}`}
  data-draw={mode}
  aria-hidden="true"
>
  <g stroke="var(--c)" stroke-width="1.25" opacity="0.85">
    <path d="M0 60 H70 L90 40 H160" />
    <path d="M90 40 V16 H210" />
    <path d="M160 60 L180 80 H300 L320 60 H400" />
    <path d="M300 80 V104 H360" />
    <path d="M210 16 L230 36 V60" />
  </g>
  <g fill="var(--c)">
    <circle cx="70" cy="60" r="2.5" />
    <circle cx="160" cy="60" r="2.5" />
    <circle cx="210" cy="16" r="2.5" />
    <circle cx="300" cy="80" r="2.5" />
    <circle cx="360" cy="104" r="2.5" />
    <circle cx="230" cy="60" r="2.5" />
  </g>
  <g stroke="var(--c)" stroke-width="1" opacity="0.6">
    <rect x="84" y="34" width="12" height="12" />
    <rect x="314" y="54" width="12" height="12" />
  </g>
</svg>
